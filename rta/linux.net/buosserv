#       $1 can be linux otherwise the build is OSX x86

if     [ "$1" == "osx" ]
then    
        OSWITCH=-DOSX
else
        OSWITCH=-DLINUX
fi

gcc -m32 -funsigned-char	-DINTERFACES=6 				\
				-DINTEL	$OSWITCH			\
				-o $RTA_BINARY/linuxnet	-lpthread	\
				../emulator.rel/argue.o			\
				../emulator.rel/portal.o 		\
				../emulator.rel/ifidxa.o		\
				linuxnet.c

