rm system.txo

rm ../fs/fs.txo
rm rtaimage.txo
rm srom
rm srom.rom

masmx image -lnxkzyd system >list.txt
pushd ../lib
./make
cd ../fs
masmx fs fs -lnxkzyFd >list.txt
cd ../drivers
masmx drivers drivers -lnxkzyd >list.txt
cd ../async
masmx async2 async2 -lnxkzyd >list.txt
popd
masmx bank rtaimage -lnubxkd >>list.txt
$RTA_BINARY/lstring -b rtaimage.txo srom
$RTA_BINARY/slab -v srom srom.rom 40 -k
