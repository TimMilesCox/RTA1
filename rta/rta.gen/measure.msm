	lb	3, a	. uplink to last in priority chain
	sx	3, a	. new last <-
	sx	0, b	. old_last->next
	sa	0, x	. ->next = stem_post

choose			. now load another task

	la,xi	stem(PRIORITIES)
forward	lb	a_x
	la	0, a
	tz	2, a	. clear to run?
	j	forward

	lx	0, a	. ->next becomes previous->next
	sx	0, b

	tp	1, x	. is he the stem post?
