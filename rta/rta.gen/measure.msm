	dsr	6
	sbr	18
	j	store_upacket
application_bank
	dsr	3
	sbr	21
	sal	3

store_upacket
	ds	UPACKET+2	. set thread transfer

	la	0, sp		. read bank name again
	and, xi	-64		. beginning with vector 0
				. write the 64 entry points
				. into the vector bank

p	$proc
v64*	$name
	sa	VECTOR(?)
	aa, xi	1
	$end

?	$do	64,	v64

.        la      (TRANSFER_PAGE/*12)      . set default return
.        lb, xi  return_exit
.        ds      RSAVE+126
.        la, i   126

	la, xi	128
	
