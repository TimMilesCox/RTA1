	ly	$3("loadable":0),,xi
	lr	3,,xi
	dsr	48
	call	(fs_find)
	jza	load_request
	lr	3,,xi
	ly	$3("beast.rom"),,xi
	call	(fs_dsearch)
	jza	load_request
	call	(fs_xbase)

	la	262144-32768/*12,,xi
	sabr	16

and_the_rest*	$proc
	la	1, a, i
	sabr	16+?
	$end

?	$do	7,	and_the_rest

	lr	32768/4-1,,xi
	lx	(16*/12)
copyup	qpush	0, y
	qpop	0, x
	ax	4,,xi
	ay	4,,xi
	jdr	copyup

	la	(0C00001)
?	$do	8,	sabr	16+?-1

	printf	$3("beast.rom loaded":10:0),,xi	
