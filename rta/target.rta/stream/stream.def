stdin	$equf	0,,xi
stdout	$equf	1,,xi
stderr	$equf	2,,xi

p	$proc
scanf*	$name
	fscanf	stdin,,xi p()
	$end

p	$proc
fscanf*	$name
	c	(fscanform) p()
	$end

p	$proc
printf*	$name
	c	(fprintf)	stdout,,xi	p()
	$end

p	$proc
sscanf*	$name
	c	(scanform) p()
	$end

	$if	0
p	$proc
sprintf* $name
	c	(editform) p()
	$end
	$endif

p	$proc
fread*	$name

	$if	$t(p(2, 1))
_LENGTH	$equf	p(2, 1)
	$else
_LENGTH	$equf	p(2, 1)*p(3, 1),,xi
	$endif

	c	(read)	p(4, 1)	p(1, 1),,i	_LENGTH
	$end

p	$proc
fwrite*	$name

	$if	$t(p(2, 1))
_LENGTH	$equf	p(2, 1)
	$else
_LENGTH	$equf	p(2, 1)*p(3, 1),,xi
	$endif

	c	(write)	p(4, 1)	p(1, 1),,i	_LENGTH
	$end

p	$proc
fgets*	$name

	$if	$t(p(2))
_LENGTH	$equf	p(2)
	$else
_LENGTH	$equf	p(2, 1),,xi
	$endif

	c	(read)	p(3, 1)	p(1, 1),,i	_LENGTH
	jna	$+3
	dsr	24
	wsr	24
	$end

p	$proc
fflush* $name

	c	(fsync)	p(1, 1)
	$end

