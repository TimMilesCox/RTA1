stdin	$equf	0,,xi
stdout	$equf	1,,xi
stderr	$equf	2,,xi

p	$proc
scanf*	$name
	fscanf	stdin	p()
	$end

p	$proc
fscanf*	$name
	c	(__fscanf) p()
	$end

p	$proc
fprintf* $name
	c	(__fprintf)	p()
	$end

p	$proc
printf*	$name
	fprintf	stdout	p()
	$end

p	$proc
sscanf*	$name
	c	(__sscanf) p()
	$end

p	$proc
sprintf* $name
	c	(__sprintf) p()
	$end

p	$proc
fread*	$name
_LDES1	$set	0
_LDES2	$set	0
	$do	$t(p(2, 1))=0,	$do	p(2)<3,_LDES1,	$set	xi
	$do	$t(p(3, 1))=0,	$do	p(3)<3,_LDES2,	$set	xi
	c	(readll)	p(4)	p(1)	p(2),,_LDES1	p(3),,_LDES2
	$end

p	$proc
fwrite*	$name
_LDES1	$set	0
_LDES2	$set	0
	$do	$t(p(2, 1))=0,	$do	p(2)<3,_LDES1	$set	xi
	$do	$t(p(3, 1))=0,	$do	p(3)<3,_LDES2	$set	xi
	c	(writell)	p(4)	p(1)	p(2),,_LDES1	p(3),,_LDES2
	$end

p	$proc
fgets*	$name
_LDES	$set	0
	$do	$t(p(2, 1))=0,	$do	p(2)<3,_LDES	$set	xi
	c	(read)	p(3)	p(1)	p(2),,_LDES
	jna	$+3
	dsr	24
	wsr	24
	$end

p	$proc
fflush* $name
	c	(fsync)	p(1, 1)
	$end

