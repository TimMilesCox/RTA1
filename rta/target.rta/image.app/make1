masmx -kw $1 $1.abs
lstring -bL $1.abs lsegment '(1,3)'
masmx -kw ../image.app/rigger rigger $1.abs
symbol < rigger.txo export > outrigger
source ./outrigger
echo FS offset $OUTRIGGER
1gformat -x $1.fs $OUTRIGGER < fsload
masmx ../image.app/load $1 $OUTRIGGER -lnke
symbol < $1.txo export > storage
lstring -b $1.txo $1
source ./storage
slab $1 $1.rom $STORAGE
