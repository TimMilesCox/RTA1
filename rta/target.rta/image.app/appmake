rm		$1.abs
rm		$1.seg
masmx -dk	$1 $1.abs
masmx -k	../image.app/makedseg $1.seg $1 -lnke
symbol < $1.seg > fs_offset
lstring	-b	$1.seg segload
source	./fs_offset
1gformat -x	$1.fs $FS_OFFSET < loadlist
masmx -ku	../image.app/load $1.txo $1
symbol < $1.txo > banks
source	./banks
lstring -b	$1.txo $1
slab -v		$1 $1.rom $LOAD

