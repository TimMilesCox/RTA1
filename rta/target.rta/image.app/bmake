rm	$1
rm	*.abs
rm	*.txo

if	[ -e make_rel ]
then
	rm	*.rel
	./make_rel
	masmx -kwX $1 $1.abs

else

	masmx -kw $1 $1.abs
	lstring -bL $1.abs lsegment '(1,3)'
fi

masmx -kwX ../image.app/trigger trigger $1.abs
symbol < trigger.txo export > outrigger

./make_pro

#	if	[ ! -e $1_profile.txo ]
#	then
#	echo	run profile make not completed
#	exit
#	fi

source ./outrigger
echo FS offset $OUTRIGGER
1gformat -xy $1.fs $OUTRIGGER < loadfs
masmx ../image.app/load $1 $OUTRIGGER -lnkeX
symbol < $1.txo export > storage
lstring -bL $1.txo $1
slab $1 $1.rom -p
diff --brief $1_txo.zak $1.txo
cmp $1.zak $1
diff --brief outrigger.zak outrigger
diff --brief storage.zak storage
diff --brief trigger_txo.zak trigger.txo
cmp $1_rom.zak $1.rom
./amass
