	$list		0
	$path		../
	$include	def/map1.def
	$list
	$path

	$trace		LOADA
	$trace		LOADP

	$text,2		/_APP/
	$text,3		/_FSO/

	$include,$binary	_APP.abs	$(0,4)
$(50:_FSO)
	$include,$binary	_APP.fs

	$do	$t(FS_SAFE_LIMIT)=0,;
FS_SAFE_LIMIT	$set	4095

	$do	$>FS_SAFE_LIMIT,	;
	$flag	add page[s] to iframe containing segment load FS

STORAGE* $equ	$zenith+4095**-4096
