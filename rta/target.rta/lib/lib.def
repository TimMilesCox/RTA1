.	BYTES		$equ	d$save

floating_scan		$equ	fscan
floating_edit		$equ	fedit
floating_iedit		$equ	fediti
floating_edit192	$equ	fedit192
symbol_scan		$equ	symbol
floating_scan192	$equ	fscan192
integer_edit		$equ	ieditu
edit			$equ	iedit
edits			$equ	iedits
edit48			$equ	iedit48_xdr
edit48u			$equ	iedit48u_xdr
edit48s			$equ	iedit48s_xdr
edit72			$equ	iedit72_xdr
edit72u			$equ	iedit72u_xdr
edit72s			$equ	iedit72s_xdr

iscan_skip		$equ	iscan_skip_xdr

iscan			$equ	iscan_xdr
iscan48			$equ	iscan48_xdr
iscan72			$equ	iscan72_xdr

xdr_floating_scan	$equ	fscan
xdr_floating_edit	$equ	fedit
xdr_floating_iedit	$equ	fediti
xdr_symbol_scan		$equ	symbol
xdr_integer_edit	$equ	ieditu

. xdr_opaque_read		$equ	LIBRARY_XDR/*6++61	. all changed to $vector
. ieee754_64_2float	$equ	LIBRARY_XDR/*6++60		. it's safer
. float2_ieee754_64	$equ	LIBRARY_XDR/*6++61
. xdr16_ieee754_64_2float	$equ	LIBRARY_XDR/*6++62
. xdr16_float2_ieee754_64	$equ	LIBRARY_XDR/*6++63
