
	$if	_BASE
_LOADP	$equ	0
	$else	
	$trace	_LOADA	. make sure that is unresolved index 0
	$trace	_LOADP	. and therefore that is unresolved index 1
	$endif

_FRAMES	$set	0

p	$proc
largo*	$name	go
larcal* $name	call

_OMAXP	$set	"p(1, 1:1):_OMAX"
_MASK	$set	"p(1, 1:1):_M"

	$do	p(1,1)>_OMAXP,	$flag	offset > iframe
	$do	p(0, 0)=go,	;
	go	(0800000++$4(_M+_LOADP+(p(1, 1)**262143)*/24d)s)
	$do	p(0, 0)=call,	;
	c	(0800000++$4(_MASK/*24++(p(1, 1)**262143), _MASK+_LOADP:d)s)	p(2)	p(3)	p(4)
	$end

p	$proc
"$xvector"* $name	1
"$xname"*   $name	2
*	$set	p(1, 1)++$*/24
	$do	p(0,0)=$xvector,	;
	j	p(2, 1)
	$end

p	$proc	$(0)
"$iframe"* $name
_P	$set	$bank_index+$zenith+4095/*12
_Q	$set	p(0, 2)
_F	$set	0
	$do	_Q^=0,_F	$set	0800000
	$do	_Q=7,_F		$set	0400000
_OMAX*	$equ	4096*_Q+4095
_M*	$equ	_F++_P++_Q*/42

_FRAMES* $set	_FRAMES+1
_FRAME(_FRAMES)* $set	_Q*4096+4096
_IMAGE_WORDS $set	0
?	$do	_FRAME(),_IMAGE_WORDS $set _IMAGE_WORDS+_FRAME(?)

$(0::4096*_P)
_B	$equ	$bank_index
	$do	_P>_B/*12,	;
	$flag	frame restarted 1 page higher: forward references slipped
	
_XHI	$equ	$zenith-1/*12
	$do	_Q<_XHI,	;
	$flag	actual page high index > $iframe,EXPECTED_PAGE_HIGH_INDEX

?	$do	p(),;
	"p(?,1:1)"***	$xvector	_M	p(?, 1:2)
	$list	0
	$do	64-$,	fret	0
	$list
	+	_M+_LOADP:d		. muster gate
	+	_IMAGE_WORDS
	$end

p	$proc
"$lits4"* $name
	$lit	4
_INDEX	$set	$bank_index
$(4::_INDEX)
$(4:256)
$(0:256)
_LITERALS4* $set	20
	$do	p()^=0,_LITERALS4*	$set	p(1, 1)
	$res	_LITERALS4
	$end

p	$proc	$(4)
"$check4"* $name
spare	$set	_LITERALS4+256-$zenith(4)
	$do	spare<0,	;
	$flag	$lits4 argument needs to be at least
	$do	spare>0,	;
	$note	$lits4 argument can be reduced to
	$do	spare^=0,	;
	$trace	$zenith-256
	$end

"$4"	$lit	4
