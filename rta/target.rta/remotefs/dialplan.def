p	$proc	*
mount_list* $name
	+	p()
?	$do	p(),	+	p(?, 1), ("p(?, 1)":0:0)d
list_end
	$end

p	$proc	*
pmount_list* $name
b4	$equ	$lit		. push literal default locator
	$lit	3		. send literals into static
	+	p()
?	$do	p(),	+	p(?, 1), ("p(?, 1)":0:0)d
list_end
	$lit	b4		. pop literal default locator
	$end
