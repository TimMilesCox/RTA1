X_EXIT	$equ	0
X_LOAD	$equ	1
X_LOAD_NEGATIVE $equ 2
X_PUSH	$equ	3
X_ADD	$equ	4
X_ADD_NEGATIVE $equ	5
X_MULTIPLY	$equ	6
X_DIVIDE	$equ	7
X_SQUARE_ROOT	$equ	12
X_POP_ADD	$equ	8
X_POP_ADD_NEGATIVE $equ 9
X_POP_MULTIPLY     $equ 10
X_POP_DIVIDE	$equ	11
X_POP_SQUARE_ROOT  $equ	13
X_CODES	$equ	14

FPONLINE_MESSAGE_LIMIT $equ 200
FPONLINE_PORT	$equ	131

"$command" $form	24, 24

f	$func
"$192"*	$name
pointer	$equf	$0(major_minor	f(1, 1))
	$return	pointer
	$end

p	$proc
"$x_load"* $name
	$command	X_LOAD, p(1, 1)
	$end

p	$proc
"$x_load_negative"* $name
	$command	X_LOAD_NEGATIVE, p(1, 1)
	$end

p	$proc
"$x_reserve"* $name
	$command	X_PUSH, p(1, 1)
	$end

p	$proc
"$x_"* $name
	$end

p	$proc
"$x_add"* $name
	$command	X_ADD, p(1, 1)
	$end

p	$proc
"$x_subtract"* $name
	$command	X_ADD_NEGATIVE, p(1, 1)
	$end

p	$proc
"$x_multiply"* $name
	$command	X_MULTIPLY, p(1, 1)
	$end

p	$proc
"$x_divide"* $name
	$command	X_DIVIDE, p(1, 1)
	$end

p	$proc
"$x_retrieve_add"* $name
	$command	X_POP_ADD, 0
	$end

p	$proc
"$x_retrieve_subtract"* $name
	$command	X_POP_ADD_NEGATIVE, 0
	$end

p	$proc
"$x_retrieve_multiply"* $name
	$command	X_POP_MULTIPLY, 0
	$end

p	$proc
"$x_retrieve_divide"* $name
	$command	X_POP_DIVIDE, 0
	$end

p	$proc
"$x_square_root"* $name
	$command	X_SQUARE_ROOT, p(1, 1)
	$end

p	$proc
"$x_pop_square_root"* $name
	$command	X_POP_SQUARE_ROOT, 0
	$end

p	$proc
_root*	$name
	$if		p()
	$xqt_fp,$192	p()
	$else
	$xqt_fp,$192	$TOTAL
	$endif
	$x_square_root
	$end

