	$path		../
	$include	lib/144.def
left	$set,168	2
right	$set,168	2.0
	+	$normalised(168,144,left)
	+	$normalised(168,144,right)
nzero	$set,168	0
pzero	$set,168	-0.0
	+	$normalised(168,144,nzero)
	+	$normalised(168,144,pzero)

	major_minor	left
	major_minor	right
	major_minor	nzero
	major_minor	pzero
	major_minor	0.0
	major_minor	-0
	major_minor	-0.0
	major_minor	-1.0
	major_minor	-2
	major_minor	3
