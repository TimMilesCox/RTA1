"$length"* $func
	$do	$PASS=1, $return	44
	$return	APDATA+40
	$end

"$ones"* $func
total	$set	0
fields	$set	$ones(1)
?	$do	fields,total	$set	total+$ones(1, ?)
total	$set	(total**0FFFF)+(total/*16)
total	$set	(total**0FFFF)+(total/*16)
	$return	total
	$end

"$neta"* $func
	$sterm	'.'
octets	$set	0
?	$do	$neta(1, 1:),octets	$set	octets*/8++$neta(1, 1:?)
	$sterm	':'
	$return	octets
	$end


p	$proc
iph*	$name
*	$record	p(1, 1) p(1, 2) p(1, 3) p(1, 4) p(1, 5) $ones(p())--0FFFF, p(1, 7) p(1, 8)
vihl	16
bytes	16
id	16
fragm	16
ttlp	16
csum	16
source	32
dest	32
	$root
	$end

"$sequence"* $func
	$do	$PASS=1,	$return	APDATA*2-1
	$return	$PASS*APDATA
	$end

"$hl_code"* $func
	$do	$PASS=1,	$return	06000++TCP_SYN
	$return	05000++TCP_ACK++TCP_PSH
	$end


p	$proc
tcph*	$name
*	$record p(1, 1) p(1, 2) p(1, 3) p(1, 4) p(1, 5) p(1, 6) p(1, 7) p(1, 8) 02040000++572
frport	16
toport	16
seq	32
ack	32
hl_code	16
window	16
csum	16
urgent	16
	$do	$PASS=1,mss_option	32
	$root
	$end

p	$proc
apdu1*	$name
*	$record	p(1, 1) p(1, 2) p(1, 3)
position
	$do	$PASS=1,id	32
	$do	$PASS>1,id	64
key	192
sum	96
	$root
	$end	

DGRAM	$set	40+APDATA
SALVO	$set	DGRAM*WIDTH

p	$proc
traffic_datagram* $name
*	$record
ip	iph	04500, $length, $PASS, 04000, 03c06, 0, $neta(p(1, 1)), $neta(p(2, 1))
tcp	tcph	p(1, 1:2), p(2, 1:2), $sequence, 0, $hl_code, 0FFFF, 0, 0
apdu	apdu1	$PASS*SALVO+$COLUMN*DGRAM-DGRAM, p(3, 1), p(4, 1)
	$root
	$end

p	$proc
fin_datagram* $name
*	$record
ip	iph	04500, 40, $PASS, 04000, 03c06, 0, $neta(p(1, 1)), $neta(p(2, 1))
tcp	tcph	p(1, 1:2), p(2, 1:2), $sequence, 0, $hl_code**0F000++TCP_FIN++TCP_ACK, 0FFFF, 0, 0
apdu	apdu1	SALVO*($PASS+1)+$COLUMN*DGRAM-DGRAM	, p(3, 1), p(4, 1)
	$root
	$end

