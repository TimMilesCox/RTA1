
p	$proc
largo*	$name"
_P	$set	"p(1, 1:1):_B"/*12
_Q	$set	"p(1, 1:1):_Q"
_OMAX	$equ	4096*_Q+4096+4095
	$do	p(1,1)>_OMAX,	$flag	offset > iframe
_F	$set	0
	$do	_Q^=0,_F	$set	0800000
	$do	_Q=7,_F		$set	0400000
	$plist	10
	go	(0800000++$0(_F++_P++(p(1, 1)**262143)*/24++_Q*/42d)s)
	$plist
	$end

p	$proc	$(0)
"$iframe"* $name
_P*	$equ	$bank_index+$zenith+4095/*12
_Q*	$equ	p(0, 2)

$(0::4096*_P)
	$do	_P>_B/*12,	;
	$flag	frame restarted 1 page higher: forward references slipped
	
_B*	$equ	$bank_index
_XHI	$equ	$zenith-1/*12
	$do	_Q<_XHI,	;
	$flag	actual page high index > $iframe,EXPECTED_PAGE_HIGH_INDEX

?	$do	p(),"p(?,1:1)"**	$vector	p(?, 1:2)
	$list	0
	$do	64-$,	fret	0
	$list
	+	_XHI,,0
	$end

