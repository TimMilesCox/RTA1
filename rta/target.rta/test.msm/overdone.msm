sichan_push_ii
	lcal	sichan_store	. save stream state
	dec	ICHANNEL_STAC
	sx	*ICHANNEL_STAC
	lx	a		. parameter in application register a
	lcal	sichan_load	. load next stream state
	ir	0

sichan_pop_ii
	lcal	sichan_store	. save stream state
	lx	*ICHANNEL_STAC	. parameter from saved list in TCB
	inc	ICHANNEL_STAC
	lcal	sichan_load	. load next stream state
	ir	0

sochan_push_ii
	lcal	sochan_store	. save stream state
	dec	OCHANNEL_STAC
	sx	*OCHANNEL_STAC
	lx	a		. parameter in application register a
	lcal	sochan_load	. load next stream state
	ir	0

sochan_pop_ii
	lcal	sochan_store	. save stream state
	lx	*OCHANNEL_STAC	. parameter from saved list in TCB
	inc	OCHANNEL_STAC
	lcal	sochan_load	. load next stream state
	ir	0

