
p	$proc
dmantissa* $name

passes	$set	p(3, 1)
	$do	passes>20,passes	$set	1
	$do	passes<1,passes		$set	1

dividend	$set	p(1, 1)**0FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF
divisor		$set	p(2, 1)**0FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF
quotient	$set	0

signs		$set	0

		$if	dividend**(1*/167)=0	. normalised so + = -
dividend	$set	dividend--0FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF
signs		$set	^signs
		$endif

		$if	divisor**(1*/167)=0	. normalised so + = -
divisor		$set	divisor--0FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF
signs		$set	^signs
		$endif

repeat	$set	divisor

.	$trace	dividend
.	$trace	divisor
.	$trace	signs

p	$proc
condition*	$name
quotient**	$set	quotient*/1
	$if	dividend<divisor
	$else
dividend**	$set	dividend-divisor
quotient**	$set	quotient++1
	$endif
divisor**	$set	divisor/*1
	$end

f	$func
normalise* $name
mantissa	$set	f(1, 1)
	$do	mantissa**(1*/167)^=0,	$return mantissa
?	$do	167,	$do	(mantissa*/?)**(1*/167)^=0,	;
			$return	(mantissa*/?)
	$note	no remaining mantissa
	$return	0
	$end

f	$func
pattern* $name
value	$set	f(1, 1)
	$do	value**(1*/95)^=0,	$return	value
?	$do	96,	$do	((value**0FFFFFFFFFFFFFFFFFFFFFFFF)*/?)**(1*/95)^=0,	;
			$return	(value**0FFFFFFFFFFFFFFFFFF000000000000000000000000)++;
				(value**0FFFFFFFFFFFFFFFFFFFFFFFF)*/?
	$note	no low-order part
	$return	value
	$end
	
p	$proc
alter*	$name
	$do	168,	condition
quotient*	$set	normalise(quotient)
	+	pattern(quotient)--signs:O
dividend*	$set	quotient	. normalise(quotient)
divisor*	$set	repeat
quotient*	$set	0
	$end

	$do	passes,	alter
	$end

p	$proc
mlong*	$name
multiplicand	$set	p(1, 1)**0FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF
multiplier	$set	p(2, 1)**0FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF
product		$set	0

f       $func
normalise* $name
mantissa        $set    f(1, 1)
        $do     mantissa**(1*/167)^=0,  $return mantissa
?       $do     167,    $do     (mantissa*/?)**(1*/167)^=0,     ;
                        $return (mantissa*/?)
        $note   no remaining mantissa
        $return 0
        $end

f       $func
pattern* $name
value   $set    f(1, 1)
        $do     value**(1*/95)^=0,      $return value
?       $do     96,     $do     ((value**0FFFFFFFFFFFFFFFFFFFFFFFF)*/?)**(1*/95)^=0,    ;
                        $return (value**0FFFFFFFFFFFFFFFFFF000000000000000000000000)++;
                                (value**0FFFFFFFFFFFFFFFFFFFFFFFF)*/?
        $note   no low-order part
        $return value
        $end

f	$func
contained* $name
result	$set	f(1, 1)
	$do	result/*168=0,	$return	result
?	$do	24,	$do	result/*168+?=0,	$return	result/*?
	$return	result
	$end

?	$do	144,	$do	0800000**(multiplier/*?)^=0,product $set contained(product+(multiplier*/?-1))

	$trace	multiplicand
	$trace	multiplier
	$trace	product
product $set	normalise(product)
	+	pattern(product):O
	$end

