p	$proc
tomfoo*	$name
p	$proc
bamfoo*	$name
*	$tree
*	$equ	$net(BINGDEX_DINGDEX)
up	$equ	p(5, 1:1)
down	$equ	p(5, 1:2)
when_they_were_neither	$equ	p(5, 1:3)
BINGDEX_DINGDEX**	$set	BINGDEX_DINGDEX+1
	$root
	$end
	$do	grapple(BINGDEX_DINGDEX)=0,;
grapple(BINGDEX_DINGDEX)**	bamfoo	p()
	$end

BINGDEX_DINGDEX	$set	1

	tomfoo	1 2 3 4 100:2:90
	tomfoo	1 2 3 4 400:256:44

