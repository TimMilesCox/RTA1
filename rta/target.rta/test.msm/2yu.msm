	$include	../def/rta.def
	$include	../language/stack.def
	$include	../t77.4/ip.def

$(3:03000/$3)
so_udp	0
so_tcp	0

$(0:0)
	+	(0, $neta(10.2.0.5:10001)q)
	+	($neta(10.1.0.5:9999), $neta(10.2.0.5:10001)q)

	socket	AF_INET	?	IPPROTO_UDP
	sa	so_udp
	jna	complain(1)

	socket	AF_INET	noodle_soup_stream	IPPROTO_TCP
	sa	so_tcp
	jna	complain(2)

	c	(connect)	so_udp	(0, $neta(10.2.0.5:10001)q)
	c	(connect)	so_tcp	($neta(10.1.0.5:9999), $neta(10.2.0.5:10001)q)	

	$do	$<256,$(0:256)
