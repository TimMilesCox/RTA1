
.	leading octet of an options field

IPO_COPY	$equ	128

IPO_EOLIST	$equ	0	. test unmasked these are 8 bits
IPO_NO_OP	$equ	1	. and no following length ++ values

IPO_CLASS_ZERO		$equ	0
IPO_CLASS_RESERVED	$equ	1*/5
IPO_CLASS_INSTRUMENTAL	$equ	2*/5
IPO_CLASS_COMPARTMENT	$equ	IPO_CLASS_INSTRUMENTAL
IPO_CLASS_NUMBERED	$equ	3*/5

IPO_CLASS_MASK		$equ	IPO_CLASS_NUMBERED 
IPO_CLASS_HAS_LENGTH_B	$equ	IPO_CLASS_INSTRUMENTAL

IPO_INSTRUMENTAL_FIXLEN	$equ	11

IPO_NUMBER_MASK		$equ	31
IPO_LOOSE_SRC_ROUTING	$equ	3
IPO_TIGHT_SRC_ROUTING	$equ	9
IPO_RECORD_ROUTE	$equ	7
IPO_STREAM_ID		$equ	8
IPO_INET_TIME_STAMP	$equ	4++IPO_CLASS_INSTRUMENTAL

.	to copy on fragmentatio
n
.	IPO_CLASS_INSTRUMENTAL
.	IPO_LOOSE_SRC_ROUTING


.	to copy on forwarding

.	IPO_TIGHT_SRC_ROUTING	on 1 fragment
.	IPO_RECORD_ROUTE	not copied to fragments.
.				extended++ and forwarded
.	IPO_INET_TIME_STAMP	flagged:
.				1: extend++ list 32-bit ? timestamps
.				2: extend++ list 32-bit ? netaddress ++ timestamps
.				3: plug in timestamp if this host listed
							
