	$include	../t77.4/tcp.def
	$include	hvtrafic.def

MANY	$equ	5
WIDTH	$equ	10
APDATA	$equ	44

"$PASS"	$do	MANY,"$COLUMN"	;
	$do	WIDTH,frame($PASS,$COLUMN)	traffic_datagram	10.0.0.$COLUMN:5000	;
									172.29.7.7:16387	;
									"NH67004400660088":'0'++$COLUMN:"00J" ;
									1.75

"$COLUMN"*	$do	WIDTH,fin_frame($COLUMN)	fin_datagram	10.0.0.$COLUMN:5000	;
									172.29.7.7:16387

