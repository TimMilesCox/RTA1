	$path		../
	$include	def/rta.def
	$include	def/ii.def
	$include	language/stack.def
	$include	fponline/fponline.def
	$path

FPONLINE $equ	0A000

$(3:03000)
fponline_buffer
	$res	FPONLINE_MESSAGE_LIMIT

$(0::FPONLINE)
fpo*	$vector	fpol
	$do	64-$,	fret	0

	$list	2
	$include	../fponline/fponline
	$list

fpol
fpol_next
	c	(rx)
	jna	fpol_quit
	ly	fponline_buffer,,xi
	lcal	fponline
	call	(floating_edit192)
	c	(tx)
	j	fpol_next
fpol_quit
	ii	EXIT$
	$do	$<256,$(0:256)
