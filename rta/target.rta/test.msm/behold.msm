	$path		../
	$include	def/rta.def
	$include	def/ii.def
	$include	language/stack.def
	$path
	$include	psfpcode.def
FPONLINE $equ	0A000
$(3:03000)
pseudoprogram_buffer
	$res	200
PSEUDOPROGRAM_LIMIT
$(0::FPONLINE)
fponline*	$vector	fpol
	$do	64-$,	fret	0
fpxqt
	$list	2
	$include	fponline
	$list
	lret	0
fpol
fpol_next
	c	(rx)
	jna	fpol_quit
	ly	pseudoprogram_buffer,,xi
	lcal	fpxqt
	c	(tx)
	j	fpol_next
fpol_quit
	ii	EXIT$
	$do	$<256,$(0:256)
