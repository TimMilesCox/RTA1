	$path		../
	$include	def/rta.def
	$include	language/stack.def
	$include	language/fpxpress.def
	$include	language/i_xpress.def
	$path

croo	$equ	1.875

$(0:64)
	$head_near	 params(hoo,	long	;
				boo,	long	;
				mask,	long	;
				crypto,	long	)

	$xqt_i		15 - 175 * 2d
	$xqt_i		15 - 172 * (-2)d
	$xqt_i		15 - 172 * -2d
	$xqt_i		15 + 172 * 2d

	$xqt_i		0c00000000000:d ++ ((15 + 172 * 2d ** mask) * -5 -- crypto)

	$xqt_i		mask */ 3 -- crypto /* 2

	$xqt_i		banga + -lore / -4

	$xqt_i		*01F80 + *01F81
	$xqt_i		*01F80 * *01F81
	$xqt_i		*05080 - *05081
	$xqt_i		*05080 / *05081

	$xqt_i		hoo */ 1	;
		++	boo */ 2	;
		++	mask */ 3	;
		++	crypto */ 4

	15 - 175 * 2
	15 - 175 * -2
	5 + -4
	5 + -4

	-4 * 3 * 3
	-4 * 3 * -3
	-4 * 3 * -3 - 16  - hampers
	-hampers - 16 - 4 * 3 * -3
	-4 * 3 * -3 - hampers - 16
	11 + 3 * -4 * 3 + hampers + 16
	

	-banga-lore

	$do	$<256,$(0:256)
