major_minor* $proc
f	$func
normalisep2* $name
?	$do	72,	$do	((f(1, 1)/*72-?)--signs)**1,	$return	?-1
	$return	?
	$end
sum	$set,168	major_minor(1, 1)
	$do	$zfloat=0,;
sum	$set,168	major_minor(1, 1)*+0

	+	sum*/-72q
signs	$set	sum*/-167
residual_normalising_count $set normalisep2(sum)
	$if	residual_normalising_count<72
residual_characteristic $set ((sum*/-144)--signs)-72-residual_normalising_count--signs
	$else
residual_characteristic	$set signs
	$endif
residual_mantissa	$set sum*/residual_normalising_count++signs**(1*/residual_normalising_count)-1
	+	residual_characteristic*/72++residual_mantissa**(1*/72)-1q
	$end

