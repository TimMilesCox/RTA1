
p	$proc
column8* $name
LIMIT	$equ	1024*4096
	$do	p()>2
LIMIT	$equ	p(3, 1)

	$if	LIMIT>4096
	c	(__octet4M)	p()
	$else
	c	(__octet)	p()
	$endif

	$if	p()>3
	j	p(4)
	$else
	ii	GUARD$
	$endif


load_octet	$tree
	$head_far	 params(base,	int	;
				index,	int	;
				limit,	int)	;
						;
			scalars(callerb,	int	b;
				rkxy,		float,	r)

	lb	index
	mf	(0555556)
	


	$root

load_octet4M	$tree
	$root

	



p	$proc
bumpy*	$name
RECIPRO	$equ	0555556
INDEX	$equ	p(1, 1)**03FFFFF
	+INDEX*RECIPRO/*24, 3**(INDEX*RECIPRO/*22)d
	+(p(1, 1))/3, +(p(1, 1))///3d
	$end

?	$do	5,	bumpy	?-1
	999/3
?	$do	6,	bumpy	999+?-1
	999999/3
?	$do	6,	bumpy	999999+?-1
	+(1024*1024-1)/3
?	$do	6,	bumpy	1024*1024-1+?-1
	3999999/3
?	$do	6,	bumpy	3999999+?-1
	6999999/3
?	$do	6,	bumpy	6999999+?-1
	9999999/3
?	$do	6,	bumpy	9999999+?-1
	+(1024*2048-1)/3
?	$do	6,	bumpy	1024*2048-1+?-1
	+(1024*4096-7)/3
?	$do	6,	bumpy	1024*4096-7+?-1
	+(1024*4096-1)/3
?	$do	6,	bumpy	1024*4096-1+?-1
	+(1024*8192-1)/3
?	$do	6,	bumpy	1024*8192-1+?-1
	16777215/3
?	$do	6,	bumpy	16777216-6+?-1
	16777215/3, 16777215///3d
