p	$proc

oklang*	$name

signs	$set	p(1, 1)*/-191
signs1	$set	p(2, 1)*/-191
exponent $set	(p(1, 1)--signs)/*168
exponent1 $set	(p(2, 1)--signs1)/*168
magnitude_characteristic_difference $set exponent-exponent1

	$trace	exponent
	$trace	exponent1

	$trace	magnitude_characteristic_difference

f	$func
normalise* $name
mantissa	$set	f(1, 1)
	$do	mantissa**(1*/167)^=0,	$return mantissa
	$trace	mantissa
?	$do	167,	$do	(mantissa*/?)**(1*/167)^=0,	;
			$return	(mantissa*/?)
	$note	no remaining mantissa
	$return	0
	$end

f	$func
pattern* $name
value	$set	f(1, 1)
	$trace	value
	$do	value**(1*/95)^=0,	$return	value
?	$do	96,	$do	((value**0FFFFFFFFFFFFFFFFFFFFFFFF)*/?)**(1*/95)^=0,	;
			$return	(value**0FFFFFFFFFFFFFFFFFF000000000000000000000000)++;
				(value**0FFFFFFFFFFFFFFFFFFFFFFFF)*/?
	$note	no low-order part
	$return	value
	$end

	$if	magnitude_characteristic_difference<0
	$note	other way round
	$else

biased	$set	((signs1*/168)++(p(2, 1)**0FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF));
		*/-magnitude_characteristic_difference)

addend	$set	p(1, 1)**0FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF000000++(0C00000--signs)
	$trace	addend
	$trace	biased
sum	$set	normalise(addend+biased)

	$endif
	+	pattern(sum--signs)O
	$end
