COMMANDS $equ	d$save	. count of pseudo-instructions in the remote assembly
ZENITH	$equ	d$save1	. limit of literal table in the remote assembly

	lx	sp
	sx	d$save2
	ly	(pseudoprogram_buffer)
	dl	0, y
	ds	COMMANDS

	aa	-PSEUDOPROGRAM_LIMIT,,xi
	jc	outrage
	ab	-PSEUDOPROGRAM_LIMIT,,xi
	jc	outrage

command	lr	COMMANDS
	ay	2,,xi
	jyge	exit
	lx	0, y
	lr	X_CODES,,xi
	jxge	outrage
	lr	ZENITH
	j	$+1, x
	j	exit
	j	load
	j	load_negative
	j	opush
	j	add
	j	add_negative
	j	multiply
	j	divide
	j	pop_add
	j	pop_add_negative
	j	pop_multiply
	j	pop_divide
load
	lx      1, y            . operand pointer
	jxge	outrage		. surely some mistake
	c	(fplib192_load)	x
	j	command
load_negative
	lx	1, y
	jxge	outrage
	c	(fplib192_load_negative)	x
	j	command
opush
	qpush	8
	qpush	a
	j	command
add
	lx      1, y
	jxge	outrage
	c	(fplib192_add)   x
	j	command
add_negative
	lx	1, y
	jxge    outrage
	c       (fplib192_add_negative)   x
	j	command
multiply
   lx      1, y
   jxge    outrage
   c       (fplib192_multiply)   x
	j	command
divide
   lx      1, y
   jxge    outrage
   c       (fplib192_divide)	x
	j	command
pop_add
	c	(fplib192_add)	0, sp, i
	lx	8, sp, i
	sx	sp
	j	command
pop_add_negative
	c	(fplib192_add_negative)	0, sp, i
	lx	 8, sp, i
	sx	sp
	j	command
pop_multiply
	c	(fplib192_multiply)	0, sp, i
	lx	8, sp, i
	sx	sp
pop_divide
	c	 (fplib192_divide)	0, sp, i
	lx	8, sp, i
	sx	sp
	j	command
outrage
	ql	(-0.0)
	qs	8
exit
	lx	d$save2
	sx	sp
	on	fp$r
	fa	8
	off	fp$r
	call	(floating_edit192)
