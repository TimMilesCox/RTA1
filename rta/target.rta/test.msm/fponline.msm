
fponline $tree

COMMANDS_EOP $equ d$save1		. high address commands+ in the remote assembly
ZENITH	$equ	d$save			. limit of literal table in the remote assembly
STACK_GUARD $equ d$save2
MESSAGE	$equ	d$save3

	lx	sp
	sx	STACK_GUARD
	dl	0, y
	aa	-X_CODES,,xi		. does it lool like an fponline PDU ?
	jnza	outrage

	la	b			. range test what this says
	aa	-FPONLINE_MESSAGE_LIMIT+8*2+2,,xi
	jc	outrage			. test maximum message less 2 operands

	ab	y			. change offset to address
	la	1, b			. $zenith function is only real
	ds	ZENITH			. after all literals have been generated on 2nd pass

	aa	-FPONLINE_MESSAGE_LIMIT,,xi
	jc	outrage

	sy	MESSAGE

command	lr	COMMANDS_EOP		. high address of commands list+
	ay	2,,xi
	jyge	exit
	lx	0, y
	lr	X_CODES,,xi		. a known command?
	jxge	outrage
	lr	ZENITH			. message-relative end of operands
	j	$+1, x
	j	exit
	j	load
	j	load_negative
	j	opush
	j	add
	j	add_negative
	j	multiply
	j	divide
	j	pop_add
	j	pop_add_negative
	j	pop_multiply
	j	pop_divide

load	lx      1, y				. operand index
	jxge	outrage				. surely some mistake
	ax	MESSAGE				. change offset to address
	c	(fp192lib_load)	x
	j	command

load_negative
	lx	1, y				. operand index
	jxge	outrage
	ax	MESSAGE				. change offset to address
	c	(fp192lib_load_negative) x
	j	command

opush	qpush	8
	qpush	a
	j	command

add	lx      1, y				. operand index
	jxge	outrage
	ax	MESSAGE				. change offset to address
	c	(fp192lib_add)   x
	j	command

add_negative
	lx	1, y
	jxge    outrage
	ax	MESSAGE
	c       (fp192lib_add_negative)   x
	j	command

multiply
	lx	1, y
	jxge	outrage
	ax	MESSAGE
	c	(fp192lib_multiply)   x
	j	command

divide	lx	1, y
	jxge	outrage
	ax	MESSAGE
	c	(fp192lib_divide)	x
	j	command

pop_add	c	(fp192lib_add)	0, sp, i
	lx	8, sp, i
	sx	sp
	j	command

pop_add_negative
	c	(fp192lib_add_negative)	0, sp, i
	lx	 8, sp, i
	sx	sp
	j	command

pop_multiply
	c	(fp192lib_multiply)	0, sp, i
	lx	8, sp, i
	sx	sp

pop_divide
	c	 (fp192lib_divide)	0, sp, i
	lx	8, sp, i
	sx	sp
	j	command

outrage	ql	(-0.0)		. indicate the command list didn't make sense
	qs	8

exit	lx	STACK_GUARD
	sx	sp
	on	fp$r
	fa	8
	off	fp$r
	lret	0

	$root
