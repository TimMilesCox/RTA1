p       $proc
spot*	$name
light	$set	?-1
v       $set    light*0555556    
	$if	v/*24^=light/3
	$note	exception quotient
	$trace  v
	$endif
	$if	3**(v/*22)^=light///3
	$note	exception residue
	$trace	v
	$endif
	$end

p	$proc
column*	$name
	lb	p(3)
columb*	$name
	$do	p()>3,	m	p(4)
	mf	(0555556)
	lx	p(2)
	ax	a
	sbr	22
	ex	tisch,b
$(4)
tisch
?	$do	3,	p(1, 1)	0, x, ?
$(0)
	$end
