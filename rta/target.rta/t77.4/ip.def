IPPROTO_ICMP    $equ    1
IPPROTO_TCP     $equ    6
IPPROTO_UDP     $equ    17

IP_DNF		$equ    04000

MSG_NONBLOCK	$equ	4

f       $func
"$net_ipv4"* $name

net     $set    0
        $sterm  '.'

?       $do     f(1, 1:),;
net     $set    net*/8++f(1, 1:?)

        $sterm  ':'

        $return net
        $end


"$netp" $form   32, 16

p       $proc
"$net_socket"* $name
        $netp   $net_ipv4(p(1, 1:1)), p(1, 1:2)
        $end

p	$proc
"$sockaddr"* $name
socket
pfamily	+		p(1, 1)
interface +		p(3, 1)
address	$net_socket	p(2, 1)
	$end
