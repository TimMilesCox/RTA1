
gchecksum	$tree

	$head_far	 params(protocol,	int		;
				dgram_bytes,	int		;
				acwp,		int	)	;
								;
			scalars(caller_fp,	int,	fp	)

	la	acwp			. buffer decriptor
	sa	fp
	dl	protocol
	andB	(03FFFFF)		. strip any sticky bit on byte count
	ds	6			. protocol:bytes
	lx	descriptor:uproto
	lcal	rx_jumbo:uchecksum
	pop	fp			. restore fp as at call
	fret	0

		$root	
