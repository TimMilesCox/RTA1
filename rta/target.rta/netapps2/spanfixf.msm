span_mounts
	$head_near	scalars(apps_fspointer,	int, apps_fsorder,,xi)

span_mount
	lx	apps_fspointer
	lx	0, x
	inc	apps_fspointer

	tp	x
	j	mounts_spanned			. end of list
	tnz	x
	j	span_mount			. contains no lookup directory

	la	lookfor_app:bank
	sabr	32
	ql	*(32*/12++68)
	xor	(MOUNT$,,3)
	jnza	span_mount
	c	(fsrom_da)	x	lookfor_app:bank	6,,long

	j	span_mount

mounts_spanned
	$ret	0

