$(3)
subagent_ithread
	$do	170,	0

$(0)

.	routines have static data in IP process so only callable from IP process

.	far call vector name (subagent)
.	transmission control block x-> is leased to another process a

subagent_insert
	lcal	subagent_point
	ii	LEASE$			. store the application descriptor
	fret	0			. permits more efficient checking than storing the TCB

.	far call vector name (subagent?)
.	is transmission control block x-> leased to another process?

subagent_lookup
	lcal	subagent_point
	tnz	0, b
	fret	1			. input is for primary owner of connection
	ii	LEASE$?			. is a-> still a thread control block and not stopped?
	fret	0			. a-> agrees with the target and the handle matches. Lease current
	fret	1			. it isn't or it is new and its process never had this lease

subagent_point
	lb	x
	sbr	3
	andB	255,,xi			. maximum connections in one table 169
	ab	subagent_ithread,,xi
	lret	0

