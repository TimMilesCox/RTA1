	$path		freeware/RTA1/rta/def
	$include	rta.def
	$path		freeware/RTA1/rta/language
	$include	stack.def
	$include	fpxpress.def
	$path


$(0:64)

here_sir $head_near	 params(one,	float	;
				two,	float	;
				three,	float)	;
						;
			scalars(sum1,	float	;
				sum2,	float	;
				sum3,	float)

	$fp_xqt		8.0+one+1.75+two*three

	$fp_xqt		8.5*+1*three+sum1+sum2

	$fp_xqt		sum3/(5.0-3.0)

	push, i	$$frame, sp
	pop	sp
	lret	0

	$do	$<256,$(0:256)
