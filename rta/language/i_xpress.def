"$ASIDE"	$set	8

"$push"*        $proc
                $if     $ASIDE>8
                $flag   aside buffer needs to be dynamic, written twice
		$trace	$ASIDE
		$endif
                ds      8
"$ASIDE"************************	$set    $ASIDE+2
                $end

"$pop"*         $func	*
inward		$set	$ASIDE
"$ASIDE"************************	$set    inward-2
                $if     $ASIDE<8
		$trace	$ASIDE
                $note   aside buffer underrun
"$ASIDE"************************	$set    8
                $endif
                $return $ASIDE
                $end

p		$proc

"$i_testequal"* $name
                dan     p(1)		. a result is double
                jdz     $+3
                dsr     48
                j       $+2
                lb, xi  1
                $return

"$i_testunequal"* $name
                dan     p(1)		. a result is double
                jdz     $+3
                la, xi  0
                lb, xi  1
                $return

"$i_testgreater"* $name			. a result is double
                dan     p(1)
                jdz     $+6
                jna     $+4
                la, xi  0
                lb, xi  1
                j       $+2
                dsr     48
                $return

"$i_testless"* $name
                dan     p(1)
                jdz     $+6
                jpa     $+4
                la, xi  0
                lb, xi  1
                j       $+2
                dsr     48
                $return

"$i_shift"*	$name
		$if	p(1, *1)++p(1, 2)
		dsl	p(1)
		$else			. shift distance is ea as immediate
		dsl	+p(1)		. including 1 word indirect ea
		$endif
                $return

"$i_shift_right"* $name
		$if	p(1, *1)++p(1, 2)
		dsa	p(1)
		$else
                dsa     +p(1)		. suppress literal generation
		$endif
                $return

"$i_or"*	$name
"$ea"           $equf   p(1)		. booleans are two words in parallel
                or      $ea
                orB     $ea+1
                $return

"$i_xor"*	$name			
"$ea"           $equf   p(1)
                xor     $ea
                xorB    $ea+1
                $return

"$i_and"*	$name
"$ea"		$equf	p(1)
                and     $ea
                andB    $ea+1
                $return

"$i_add"*	$name
		da	p(1)		. add / subtract are double
		$return

"$i_subtract"*	$name
		dan	p(1)
		$return

"$i_multiply"*	$name
"$ea"		$equf	p(1)		. multiplier / divisor are single

		sb	7
		lb	a
		m	$ea
		sb	6
		lb	7
		mf	$ea
		aa	6

		$return

"$i_divide"*	$name
"$ea"		$equf	p(1)
		d	$ea
		sb	7	. save the remainder
		lb	a
		la	6
		$return


"$i_covered_qotient"* $name
		$flag	covered quotient may only be a constant
		$return

"$i_remainder"*	$name
		d	p(1)
		ds	6	. save the quotient. MSW is already in 6
		la	b
		dsa	24
		$return

"$i_load"*	$name
		$if	(p(1,3)=1)++;
			(p(1,3)=2)++;
			(p(1,3)=3)++;
			(p(1,3)=4)++;
			(p(1,3)=5)
		la	p(1)
		dsa	24
		$else
		dl	p(1)
		$endif
		$return

"$i_load_negative"* $name
		$if	(p(1,3)=t1)++;
			(p(1,3)=t2)++;
			(p(1,3)=t3)++;
			(p(1,3)=i)++;
			(p(1,3)=xi)
		la, xi	0
		ana	p(1)
		dsa	24
		$else
		dsr	48
		dan	p(1)
		$endif
		$return

"$i_reserve"*	$name			. setaside is always double
		$push
		$return


"$i_retrieve_testequal"* $name
                dan	$pop
		jdz	$+3
		dsr	48
		j	$+2
		lb, xi	1
                $return

"$i_retrieve_testunequal"* $name
                dan     $pop
                jdz     $+3
                la, xi  0
		lb, xi	1
                $return

"$i_retrieve_testgreater"* $name
                dan     $pop
                jdz     $+6
		jna	$+4
		la, xi	0
                lb, xi  1
		j	$+2
		dsr	48
                $return

"$i_retrieve_testless"* $name
                dan     $pop
		jdz	$+6
                jpa	$+4
                la, xi	0
                lb, xi  1
		j	$+2
		dsr	48
                $return

"$i_retrieve_shift"* $name		. setaside shift count is LS word
"$ea"           $equ    $pop		. and is indirect
		dsl	*$ea+1
		$return

"$i_retrieve_shift_right"* $name
"$ea"           $equ    $pop
		dsa	*$ea+1
		$return

"$i_retrieve_or"* $name
"$ea"		$equ	$pop	
		or	$ea
		orB	$ea+1
		$return

"$i_retrieve_xor"* $name
"$ea"           $equ    $pop
                xor     $ea
                xorB    $ea+1
                $return

"$i_retrieve_and"* $name
"$ea"           $equ    $pop
                and     $ea
                andB    $ea+1
                $return

"$i_retrieve_add"*	$name
		da	$pop
		$return

"$i_retrieve_subtract"*	$name
		dan	$pop
		$return

"$i_retrieve_multiply"*	$name
"$ea"           $equ    $pop

		sb	7
		lb	a
		m	$ea+1
		sb	6
		lb	7
		mf	$ea+1
		aa	6

		$return

"$i_retrieve_divide"*	$name
"$ea"           $equ    $pop
		d	$ea+1
		sb	7	. save the remainder
		sa	b
		la	6
		$return

"$i_retrieve_covered_quotient"*	$name
		$flag	covered quotient may only be a constant
		$return

"$i_retrieve_remainder"*	$name
"$ea"           $equ    $pop
                d       $ea+1
		sa	7	. save the quotient. MSW is already in 6
		la	b
		dsa	24

		$end
	
