i$aside(1)	$equ	8
i$aside(2)	$equ	10
i$aside(3)	$equ	d$save
i$aside(4)	$equ	d$save2
i$aside(5)	$equ	24
i$aside(6)	$equ	26
i$aside(7)	$equ	28
i$aside(8)	$equ	30

"$$significands" $set	0
"$ASIDE"	$set	1

"$push"*        $proc
                $if     $ASIDE>8
                $flag   aside buffer overflow
		$trace	$ASIDE
		$endif
                ds      i$aside($ASIDE)
"$ASIDE"************************	$set    $ASIDE+1
                $end

"$pop"*         $func	*
inward		$set	$ASIDE
"$ASIDE"************************	$set    inward-1
                $if     $ASIDE<1
		$trace	$ASIDE
                $flag   aside buffer underrun
"$ASIDE"************************	$set    1
                $endif
                $return i$aside($ASIDE)
                $end


f		$func
"$indirect_or_indexed"* $name
		$do	f(1, *1),	$return	1
		$return	f(1, 2)
		$end

f		$func
"$1w"*		$name
		$do	f(1)<3,		$return	0
		$do	f(1, 3)<0,	$return	0
		$do	f(1, 3)>5,	$return	0
		$return	1
		$end

p		$proc

"$i_testequal"* $name
		$aax	p(1)
                dan     $aaa		. a result is double
                jdz     $+3
                dsr     48
                j       $+2
                lb, xi  1
                $return

"$i_testunequal"* $name
		$aax	p(1)
                dan     $aaa		. a result is double
                jdz     $+3
                la, xi  0
                lb, xi  1
                $return

"$i_testgreater"* $name			. a result is double
                $aax	p(1)
		dan	$aaa
                jdz     $+6
                jna     $+4
                la, xi  0
                lb, xi  1
                j       $+2
                dsr     48
                $return

"$i_testless"* $name
		$aax	p(1)
                dan     $aaa
                jdz     $+6
                jpa     $+4
                la, xi  0
                lb, xi  1
                j       $+2
                dsr     48
                $return

"$i_shift"*	$name
		$if	$indirect_or_indexed(p(1))
		$aax	p(1)
		dsl	$aaa
		$else
		dsl	+p(1)
		$endif
                $return

"$i_shift_right"* $name
		$if	$indirect_or_indexed(p(1))
		$aax	p(1)
		dsa	$aaa
		$else
		dsa	+p(1)
		$endif
                $return

"$i_or"*	$name
		$aax,y	p(1)
		$if	$1w(p(1))
		orB	$aaa
		$else			. long booleans are 2 parallel
                or      $aaa		. 1-word operations
                orB     $aaa+1
"$$significands"******** $set	48
		$endif
                $return

"$i_xor"*	$name
		$aax,y	p(1)
		$if	$1w(p(1))
		andB	$aaa
		$else
                xor     $aaa
                xorB    $aaa+1
"$$significands"******** $set	48
		$endif
                $return

"$i_and"*	$name
		$aax,y	p(1)
		$if	$1w(p(1))
		andB	$aaa
		$else
                and     $aaa
                andB    $aaa+1
"$$significands"******** $set	48
		$endif
                $return

"$i_add"*	$name
		$aax	p(1)
		$if	$1w(p(1))
		ds	6
		la	$aaa
		dsa	24
		da	6
		$else
		da	$aaa		. add / subtract are double
		$endif
"$$significands"******** $set	48
		$return

"$i_subtract"*	$name
		$aax	p(1)
		$if	$1w(p(1))
		ds	6
		la, xi	0
		ana	$aaa
		dsa	24
		da	6
		$else
		dan	$aaa
		$endif
"$$significands"******** $set	48
		$return

"$i_multiply"*	$name
		$aax	p(1)		. multiplier / divisor are single

		$if	$$significands<25
		m	$aaa
		$else

		sb	7
		lb	a
		m	$aaa
		sb	6
		lb	7
		mf	$aaa
		aa	6
		$endif
"$$significands"******** $set	48
		$return

"$i_divide"*	$name
		$aax	p(1)
		d	$aaa
		sb	7	. save the remainder
		lb	a
		la	6
		$return


"$i_covered_qotient"* $name
		$flag	covered quotient may only be a constant
		$return

"$i_remainder"*	$name
		$aax	p(1)
		d	$aaa
		ds	6	. save the quotient. MSW is already in 6
		la	b
		dsa	24
		$return

"$i_load"*	$name
		$if	($t(p(1, 3))=$name)**(p(1, 3)=111)
		p(1, 3),63	p(1, 1), p(1, 2)
		$else
		$aax	p(1)
		$if	$1w(p((1))
"$$significands"******** $set	24
		la	$aaa
		dsa	24
		$else
"$$significands"******** $set	48
		dl	$aaa
		$endif
		$endif
		$return

"$i_load_negative"* $name
		$if	($t(p(1, 3))=$name)**(p(1, 3)=111)
		p(1, 3),63	p(1, 1), p(1, 2)
		ds	i$aside($ASIDE)
		dsr	48
		dan	i$aside($ASIDE)
		$else
		$if	$1w(p(1))
"$$significands"******** $set	24
		la, xi	0
		ana	p(1)
		dsa	24
		$else
"$$significands"******** $set	48
		dsr	48
		$aax	p(1)
		dan	$aaa
		$endif
		$endif
		$return

"$i_reserve"*	$name			. setaside is always double
		$push
"$$significands"******** $set	48
		$return


"$i_retrieve_testequal"* $name
                dan	$pop
		jdz	$+3
		dsr	48
		j	$+2
		lb, xi	1
                $return

"$i_retrieve_testunequal"* $name
                dan     $pop
                jdz     $+3
                la, xi  0
		lb, xi	1
                $return

"$i_retrieve_testgreater"* $name
                dan     $pop
                jdz     $+6
		jna	$+4
		la, xi	0
                lb, xi  1
		j	$+2
		dsr	48
                $return

"$i_retrieve_testless"* $name
                dan     $pop
		jdz	$+6
                jpa	$+4
                la, xi	0
                lb, xi  1
		j	$+2
		dsr	48
                $return

"$i_retrieve_shift"* $name		. setaside shift count is LS word
"$aaa"           $equ    $pop		. and is indirect
		dsl	*$aaa+1
		$return

"$i_retrieve_shift_right"* $name
"$aaa"           $equ    $pop
		dsa	*$aaa+1
		$return

"$i_retrieve_or"* $name
"$aaa"		$equ	$pop	
		or	$aaa
		orB	$aaa+1
		$return

"$i_retrieve_xor"* $name
"$aaa"           $equ    $pop
                xor     $aaa
                xorB    $aaa+1
                $return

"$i_retrieve_and"* $name
"$aaa"           $equ    $pop
                and     $aaa
                andB    $aaa+1
                $return

"$i_retrieve_add"*	$name
		da	$pop
		$return

"$i_retrieve_subtract"*	$name
"$aaa"		$equ	$pop
		dan	$aaa
		$return

"$i_retrieve_multiply"*	$name
"$aaa"           $equ    $pop

		sb	7
		lb	a
		m	$aaa+1
		sb	6
		lb	7
		mf	$aaa+1
		aa	6

		$return

"$i_retrieve_divide"*	$name
"$aaa"           $equ    $pop
		d	$aaa+1
		sb	7	. save the remainder
		sa	b
		la	6
		$return

"$i_retrieve_covered_quotient"*	$name
		$flag	covered quotient may only be a constant
		$return

"$i_retrieve_remainder"*	$name
"$aaa"           $equ    $pop
                d       $aaa+1
		sa	7	. save the quotient. MSW is already in 6
		la	b
		dsa	24

		$end
	
