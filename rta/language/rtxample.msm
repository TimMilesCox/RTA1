	$include	fpxpress.def
	$path
$(0:0)

floating_algorithm*  $vector fp_routine

$(0:64)

fp_routine 
	$head_far	 params(one,	float		;
				two,	float		;
				three,	float)		;
							;
			scalars(temp1,	int,	x)

	$xqt_fp		one*1.75*+1200000*two/3.0*-625000-three


	lx		temp1

	push, i		$$frame, sp
	pop		sp
	fret		0

	$do		$<256,$(0:256)
	
