"$$aside"	$set	8

p		$proc
"$aax"*		$name

"$u"		$set	p(1, 1)		. drop any indirection bit
"$ix"		$set	p(0, 2)
"$iy"		$set	$ix**1

		$if	p(1, *1)**(p(1, 2)^=0)

		$if	$ix**x
		lx++$iy	$u, p(1, 2)
"$aaa"*		$equf	0, $ix
		$else
		lr++$iy	$u, p(1, 2)
"$aaa"*		$equf	*$ix
		$endif

		$elseif	p(1, *1)**($net($u)>8191)

		$if	$ix**x
		$if	$u>32767
		lx++$iy	*($u:s)
		$else
		lx++$iy	$u
		$endif
"$aaa"*		$equf	0, $ix
		$else
		$if	$u>32767
		lr++$iy	*($u:s)
		$else
		lr++$iy	$u
		$endif
"$aaa"*		$equf	*$ix
		$endif

		$elseif	($net($u)>32767)**(p(1, 2)=0)**(p(1, *1)=0)

		$if	$ix**x
		lx++$iy	$0($u:s)
"$aaa"*		$equf	0, $ix
		$else
"$aaa"*		$equf	*$0($u:s)
		$endif

		$else

"$aaa"*		$equf	p(1)
		$endif

		$end

p		$proc
"$x_add"*	$name
		$aax		p(1)
		fa		$aaa
		$return

"$x_subtract"*	$name
		$aax		p(1)
		fan		$aaa
		$return

"$x_multiply"*	$name
		$aax		p(1)
		fm		$aaa
		$return

"$x_divide"*	$name
		$aax		p(1)
		fd		$aaa
		$return

"$x_load"*	$name
		$aax		p(1)
		ql		$aaa
		$return

"$x_load_negative"* $name
		$aax		p(1)
		ql		(0.0)
		fan		$aaa
		$return

"$x_reserve"*	$name
		qs		$$aside
		$if	$$aside=8
"$$aside"******	$set	d$save
		$elseif	$$aside=d$save
"$$aside"******	$set	24
		$else
"$$aside"******	$set	$$aside+4
		$endif
		$return

"$x_retrieve_add"*	$name
		$unstack
		fa		$$aside
		$return

"$x_retrieve_subtract"*	$name
		$unstack
		fan		$$aside
		$return

"$x_retrieve_multiply"*	$name
		$unstack
		fm		$$aside
		$return

"$x_retrieve_divide"*	$name
		$unstack
		fd		$aside
		$end

"$unstack"*	$proc
		$if	$$aside=8
		$flag	fp stack underflow
		$elseif	$$aside=d$save
"$$aside"******	$set	8
		$elseif	$$aside=24
"$$aside"******	$set	d$save
		$else
"$$aside"******	$set	$$aside-4
		$endif
		$return	$$aside
                $end

