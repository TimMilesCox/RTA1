p		$proc
"$x_add"*	$name
		fa	p(1)
		$return

"$x_subtract"*	$name
		fan	p(1)
		$return

"$x_multiply"*	$name
		fm	p(1)
		$return

"$x_divide"*	$name
		fd	p(1)
		$return

"$x_load"*	$name
		ql	p(1)
		$return

"$x_load_negative"* $name
		ql	(0.0)
		fan	p(1)
		$return

"$x_reserve"*	$name
		qs	8
		$return

"$x_retrieve_add"*	$name
		fa	8
		$return

"$x_retrieve_subtract"*	$name
		fan	8
		$return

"$x_retrieve_multiply"*	$name
		fm	8
		$return

"$x_retrieve_divide"*	$name
		fd	8
		$end

