	$path		../
	$list		0
	$include	def/rta.def
	$list
	$path
	$include	tile.def

$(66::,x)
couplet	assignment_table

$(0:64)
tile	lcal	tiles_first
	lret	0

	aa, xi	+(1*/LOG(TILE)-LOG(GRANULE))-1
	sar	LOG(TILE)-LOG(GRANULE)	. tiles
	lb, xi	32
	anb	a
	lr	b			. rotate limit
	lb, xi	1
	sbl	0, a
	ab, xi	-1			. search mask
	lk	b

couple	dl	couplet:mask
	lcal	fit?	
	j	next
	ds	couplet:mask

	la	y
	sal	LOG(TILE)-LOG(GRANULE)
	dsr	24
	da	couplet:granule
	lret	1

next	lcal	tiles_forward
	lret	0	. unable to find or assign new
	j	couple

fit?	ly, xi	0
	drr	24
fit??	mta	k
	j	around
	xor	k
	drl	24, y
	lret	1

around	jxge	nane
	ay, xi	1
	drr	1
	j	fit??
nane	lret	0

