AQUIFORM_NET16 $equ	0
COUNTED_STREAM $equ	0

	$byte		6

	$path		../
	$include	def/rta.def
	$include	language/stack.def
	$include	lib/aquiform.def
	$path
	$list		2
$(0:64)
	$include	iedit48
	$include	../lib/dcode.msm

	$do	$<256,$(0:256)

table
	$list	0
hundreds	$do	10,;
tens		$do	10,;
units		$do	10,	;
	+	hundreds+'0'-1,tens+'0'-1,units+'0'-1
	$list

