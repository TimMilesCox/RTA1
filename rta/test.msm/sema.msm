	$path		../
	$include	def/rta.def
	$include	language/stack.def
	$include	language/i_xpress.def
	$include	language/fpxpress.def


p	$proc
lata*	$name	107
	$if	p(0, 2)=77
	la	p(1, 1), p(1, 2)
	lcal	i2fp
	$else
	lc	alata	p(1),,INT	$$aside,,xi
	$endif
	$end


three	$equ	1.875
factor	$equf	3,,xi

jings	$equf	buffer,,t3
crivvens $equf	buffer,,t2

$(3:03000)
one	1.5
two	1.75
first	-84

buffer	$res	1

$(0:64)

	$xqt_fp	two*three+one-first,,lata*1.009
	$xqt_i	first,,w0*/factor
	$xqt_fp	jings,,lata+crivvens,,lata

alata	$head_near	 params(input1, int		;
				where,	int	)	;
			scalars(save_a, float,	a	)

	la	input1
	lcal	i2fp
	lx	where
	qs	0, x	. park the number where the algorith expects it

	qpop	a
	lret	0

i2fp	dsa	24
	sa	6
	sa	7
	ab	a
	lsc	b
	push	a
	la	(0400000++24)
	ana	b
	pop	b
	xor	6
	lret	0

di2fp	dpush	a
	dsa	48
	sb	7
	da	0, sp
	dlsc	a
	ds	0, sp
	la	(0400000++48)
	ana	6
	xor	7
	pop	b
	pop	6
	lret	0
	

	$do	$<256,$(0:256)
