	$path		../
	$include	def/rta.def
	$include	language/stack.def
	$path

COUNT*	$func
ALL	$equ	1
bits	$set	$byte*COUNT(1, 1)-1
	$do	bits<0,bits	$set	$bits-1
	$return	bits/24*/1++COUNT(1, 2)
	$end

MASK*	$func
	$do	$byte*MASK(1, 1)///24=0,	$return	-1
	$return	-1*/24-$byte*MASK(1, 1)///24
	$end

$(3:03000)
first	$res	2
second	$res	2
istream	$res	20

$(4:04000,fp)
	$lit
bagwards $res	3
$(0:64)
frolictime $head_far	 params(hawaii,	3)	;
			scalars(pecan,	3)

	c	(ustri)	1,,xi			;	pointer
			40*$word/$byte,,xi	;	input columns
			(0,istream:d),,long	;
						;
			2,,xi			;	receive fields
			2*$word/$byte-2,,xi	;	bytes
			(16,first:d),,long	;
						;
			2*$word/$byte-1,,xi	;	bytes
			(8,second:d),,long	;
						;
			1*/1++1,,xi		;
			-1*/$byte,,xi		;
			("youse"),,long		;
			-1,,xi			;
			("hot")			;
			2*/1,,xi		;
			(-1*/$byte*2)		;
			("zambesi"),,triple	;
			2*/1++1,,xi		;
			-1*/$byte,,xi		;
			bagwards,,triple	;
			COUNT(9, ALL),,xi	;
			MASK(9),,xi		;
			hawaii,,triple		;
			COUNT(8),,xi		;
			MASK(8),,xi		;
			pecan,,triple		;		
			0,,xi

	$do	$<256,$(0:256)
