	$path		../
	$include	def/rta.def
	$include	def/ii.def
	$include	def.sys/tcb.def
	$include	t77.4/dq.def
	$include	t77.4/socket.def
	$include	t77.4/ip.def
	$path

MANAGER_BANKS	$equ	2
EVENT_WAIT$	$equ	92	. 1:28
EVENT_FREE$	$equ	93	. 1:29
PRIORITIES	$equ	8

MILLISECOND_LOG	$equ	0
INCREMENTER_HERZ     $equ 1000000000	. for example 1 nano
INCREMENTER_INTERVAL $equ INCREMENTER_HERZ/1000/*MILLISECOND_LOG
OVERFLOWER	$equ	96		. for now I/O port 96
TIME_TARGET	$equ	TCB+8

f	$func
uprate*	$name
	$return	(f(1, 1)*/10)/1000
	$end

$(66::,x)
s	$socket

$(0:64:01000)

	$list		2
	$include	events
	$do	$<256,$(0:256)

$(0:64:02000)
	la	s:flags
	jpa	$+2
	ii	EVENT_FREE$

	la	(uprate(60000))
	la	(uprate(4000000))
	la	(uprate(80))

	$do	$<256,$(0:256)


