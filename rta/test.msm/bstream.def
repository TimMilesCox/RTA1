
p	$proc
bstream* $name
*	$tree
datac	$res	1
data	$res	1
psr_flags $res	1
pointer	$res	1
	$root
	$end

SICHAN_STORE* $proc
	dl	RDATAC			. retrieve data count and buffer
	on	see$1			. switch to TCB
	lx	ACTIVE_ICHANNEL		. retrieve stream state save pointer
	ds	bchan:datac		. save data count and buffered data
	la	1, sp			. retrieve PSR read stream control flags 
	lb	q			. retrieve stream read pointer
	ds	bchan:psr_flags		. save PSR and storage read pointer
	$end

SICHAN_LOAD* $proc
	sx	ACTIVE_ICHANNEL		. write next stream state save pointer
	dl	bchan:datac		. next stream state data count and buffer
	ds	RDATAC			. set data count and buffer
	lk, xi	b$stream16r++b$streamZR	. mask PSR read control bits
	dl	bchan:psr_flags		. next stream state flags and read pointer
	sb	q			. next stream storage read pointer
	lb	1, sp			. retrieve PSR in interrupt stack frame
	mlb	a_x			. set control flags of next read stream state
	sb	1, sp			. replace updated PSR
	$end

SOCHAN_STORE* $proc
	dl	WDATAC			. retrieve data count and buffer
	on	see$1			. switch to TCB
	lx	ACTIVE_OCHANNEL		. retrieve stream state save pointer
	ds	bchan:datac		. save data count and buffered data
	la	1, sp			. retrieve PSR write stream control flags
	lb	p			. retrieve stream write pointer
	ds	bchan:psr_flags		. save PSR and storage write pointer
	$end

SOCHAN_LOAD*	$proc
	sx	ACTIVE_OCHANNEL		. write next stream state save pointer
	dl	bchan:datac		. next stream state data count and buffer
	ds	WDATAC			. set data count and buffer
	lk, xi	b$stream16w		. mask PSR write control bits
	dl	bchan:psr_flags		. next stream state flags and write pointer
	sb	p			. next stream storage write pointer
	lb	1, sp			. retrieve PSR in interrupt stack frame
	mlb	a_x			. set control flags of next write stream state
	sb	1, sp			. replace updated PSR
	$end	
