.	by default this is about free-form input in a stream

.	to process an input field of fixed size instead,
.	place the byte count in location BYTES
.	then a non-digit is returned on READ_BYTE
.	if you assemble for COUNTED_STREAM

.	BYTES is otherwise used to mark where the end
.	of network receive data is

.	if you want something less than 72 bits
.	it is returned quickly when input columns run out

.	acquiring a single or double integer causes few
.	instructions to be executed unless there are
.	excessive numerals in the input field

.	then the principle must be followed that the
.	customer is always right and integer truncation
.	is at the high order end. So the integer 
.	however large is scanned, however little of
.	it the caller wants

.	too many input significands can be retrieved as a
.	size overflow in the high order result words

.	bits 47..0 of the result are in registers a:b
.	72-bit result is int TRIPLE:TRIPLE+1:TRIPLE+2

.	size error high order field is in QUAD

	$do	'0'=0,	$do	$$EOS_FLAG=0,	;
	$note	for this data code set "$$EOS_FLAG" to nonzero after $include aquiform.def
	$do	'0'=0,	$do	COUNTED_STREAM=0,	;
	$note	for this data code equate COUNTED_STREAM to nonzero

acquire48
	lcal	magnitude72
	tp	SIGNS
	lcal	double2scomp
	lret	0

acquire72
	lcal	magnitude72
	tp	SIGNS
	lcal	triple2scomp
	lret	0

magnitude72
	z	SIGNS
	z	QUAD		. for detecting extreme size overflow
	z	TRIPLE
	z	TRIPLE+1

	lcal	isense

	z	6

	lcal	i_read6F	. this re-uses LAST_BYTE_READ
	sb	TRIPLE+2
	jxge	magnitude72x	. no columns read at all

	tz	x
	j	magnitude72x	. < 6 columns read

	lcal	i_read6
	jxge	magnitude72x	. no more columns read

	sb	7
	lb	TRIPLE+2
	mf	(1000000, 100000, 10000, 1000, 100, 10:h), x
	da	6
	ds	TRIPLE+1

	tz	x		. < 6 columns read
	j	magnitude72x

	lcal	i_read6
	jxge	magnitude72x	. no digits

	lk	(1000000, 100000, 10000, 1000, 100, 10:h), x
	lcal	raise48

	tz	x
	j	magnitude72x	. < 6 columns read, stop

	lcal	i_read6
	jxge	magnitude72x	. no columns 23..18 read

	lk	(1000000, 100000, 10000, 1000, 100, 10:h), x
	lcal	raise72

	tz	x
	j	magnitude72x	. < 6 columns read, stop

overload72
	lcal	i_read6
	jxge	magnitude72x	. no columns read, stop

	lk	(1000000, 100000, 10000, 1000, 100, 10:h), x
	lcal	raise96

	tz	x
	j	magnitude72x	. < 6 columns read, stop
	j	overload72	. applications are allowed to do this
				. integer truncation is at the 
				. high order end
magnitude72x
	dl	TRIPLE+1
	lret	0

isense	READ_BYTE
	aa, xi	-' '
	jza	isense

	$if	SIGN_LEADING
	aa, xi	' '-'-'
	jnza	isensep?
	n	SIGNS
	j	isense
isensep?
	aa, xi	'-'-'+'
	jza	isense
	$endif

	lret	0

double2scomp
	dsr	48
	dan	TRIPLE+1
	ds	TRIPLE+1
	lret	0

triple2scomp
	dsr	48
	dan	TRIPLE+1
	ds	TRIPLE+1
	sc	a
	aa, xi	-1
	ana	TRIPLE
	sa	TRIPLE
	lret	0


	$if	ISCAN_STRATEGY=2

i_read6F
	lb, xi	0
	lx, xi	6
	la	LAST_BYTE_READ
	lr, xi	6
	j	loup

i_read6	lb, xi	0
	lx, xi	6

loop	READ_BYTE
loup	aa, xi	-'0'-10
	jc	nomor
	aa, xi	10
	jnc	nomor
	dec	x


	sbl	1
	aa	b
	sbl	2
	ab	a

	tz	x
	j	loop
nomor	lret	0

	$elseif	ISCAN_STRATEGY=1

i_read6F
	lb, xi	0
	lx, xi	6
	la	LAST_BYTE_READ
	lr, xi	6
	j	loup

i_read6	lb, xi	0
	lx, xi	6

loop	READ_BYTE
loup	aa, xi	-'0'-10
	jc	nomor
	aa, xi	10
	jnc	nomor
	dec	x

	ex	table_add, x

	tz	x
	j	loop
	lret	0

nomor	jxge	none

	la, xi	0		. the table driven translate
	d	(1, 10, 100, 1000, 10000, 100000:h), x	
				. has got the scale too high
	sa	b		. because we didn't get 6 digits

none	lret	0

	$else
	$flag	ISCAN_STRATEGY must equal 1 or 2
	$endif
	

