	$path		../
	$include	def/rta.def
	$include	language/stack.def
	$include	language/fpxpress.def
	$include	language/i_xpress.def
	$path


hardly	$equ		10+seldom

$(3:03000/$3)
one	1.0
two	1.0
three	2.0

$(0:64/$0)

inward	$head_near	scalars(first,	long,	(1d)	;
				second,	long,	(2d)	;
				third,	long,	(3d))

	$if		1
	$xqt_fp		one+two+three
	$xqt_i		first+second+third
	$endif

	$if		1
	$xqt_fp		1.0+2.0+3.0
	$xqt_i		1d+2d+3d
	$endif

	$xqt_i		$0(10d)+$3(5d)+(*(seldom+6))+hippo*potamus

	$xqt_i		hippo+racoon
	$xqt_i		hippo+(*(racoon))+(*(seldom))
	$xqt_i		hippo+(*(racoon))+(*(seldom))+hippo*potamus
	$plist		8
	$xqt_i		(*(seldom))
	$plist


	$ret


	$do	$<256,$(0:256)

hippo	90d
potamus	$equ	hippo
racoon	99d
