
TARGET	$equ	8
OFFSET	$equ	9
BITS	$equ	7




fs1x	$head_far	 params(bits1,	int	;
				target1,long	;
				input1,	int)

				.	you don't know. offset is subscripted

	la	target1
	dsr	24
	d, xi	24
	aa	target1+1
	ds	TARGET
	la	bits1
	sa	BITS


				.	you do know, bits + offset > 24
				.	macro text for that case is
				.	$if	p(1, 4)+p(1, 5)>48
				.	{sa|sb}	7
				.	dl	p(1)
				.	drl	p(1, 4)
				.	sb	6
				.	sal	p(1, 5)
				.	lb	7
				.	drr	p(1, 5)
				.	lb	6
				.	drr	p(1, 4)
				.	ds	p(1)
				.	$else
				.	that avoids 10 more call sequence instructions

fs1l

	dl	*TARGET		.	UUUUUUXXXXXXYYYYYYZZZZZZ	UUUXXXXXXXXXXXXYYYYYYZZZ
	drl	*OFFSET		.	XXXXXXYYYYYYZZZZZZUUUUUU	XXXXXXXXXXXXYYYYYYZZZUUU
	sb	6
	sal	*BITS		.	YYYYYY000000SSSSSS111111	000000000000111111111111
	lb	input1
	drr	*BITS		.	111111YYYYYY000000SSSSSS	111111111111000000000000
	lb	6		.	111111YYYYYYZZZZZZUUUUUU	111111111111YYYYYYZZZUUU
	drr	*OFFSET		.	UUUUUU111111YYYYYYZZZZZZ	UUU111111111111YYYYYYZZZ
	ds	*TARGET

	$ret


fd1x	$head_far	 params(bits2,	int	;
				target2,long	;
				input2,	long	)

				.	you don't know, offset is subscripted

	la	target2
	dsr	24
	d, xi	24
	aa	target2+1
	ds	TARGET
	la	bits2
	sa	BITS
				.	macro text does other cases better

	aa	OFFSET
	aa, xi	-48

	jc	fd3		.	2 words+ to write
	aa, xi	24		.	# bits in 2nd word
	sa	6
	la	BITS
	ana	6
	sa	BITS		.	# bits in 1st word
	dl	*TARGET
	sa	10		.	save MS word target a moment
	la	input2+1	.	retrieve LS word of write value
	sbl	*6		.	insert bits in LS word of target
	dsr	*6
	sb	11		.	keep LS word result a moment
	dl	input2		.	take whole write value
	dsr	*6		.	shift out bits inserted in LS result
	la	10		.	retrieve MS word target
	drr	*BITS		.	rotate value bits to result high-order
	ral	*BITS		.	swivel to offset position
	lb	11		.	retrieve second result word
	ds	*TARGET
	$ret

fd3	sa	6
	jza	fd2		.	2nd word is an exact fit already
	dl	input2		.	some bits to write to 3rd word
	drr	*6		.	place them at the top of a
	ds	input2		.	save the new alignment
	lb	TARGET		.	read the 3rd target word
	lb	2, b
	drl	*6		.	place the write bits at low-order
	rbr	*6		.	swivel to high-order positions
	la	TARGET		.	write the 3rd target word
	sb	2, a

fd2	la	BITS		.	subtract (24 + bits written)
	lb	6
	ana, i	24, b
	sa	BITS		.	bits to insert in 1st word

	la	*TARGET		.	only read 1 word
	lb	input2
	drr	*BITS		.	copy low order bits of MS word
	ral	*BITS		.	swivel to offset position
	lb	input2+1	.	all of LS word is written
	ds	*TARGET

	$ret

