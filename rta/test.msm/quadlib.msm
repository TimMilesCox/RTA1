	$path		../
	$include	def/rta.def
	$path

ASIDE	$equ	6
LINE2	$equ	10
STREAM	$equ	d$save
CACHE	$equ	d$save1

next	lk	(-1*/$word-$byte)
	tz	STREAM
	j	acquire
	push,xi	-$byte
	popA	CACHE
	sar	$byte
	dsl	$byte
	sa	ASIDE
	la	LINE2
	ral	$byte
	mlb	a
	sb	ASIDE+1
	sar	$byte
	lb	LINE2+1
	dsl	$byte
	ds	LINE2
	dl	ASIDE
	lret	0

acquire	dec	STREAM
	sar	$byte
	dsl	$byte
	sa	ASIDE
	la	LINE2
	ral	$byte
	mlb	a
	sb	ASIDE+1
	sar	$byte
	rsr	$byte
	rar	$byte
	lb	LINE2+1
	drl	$byte
	ds	LINE2
	dl	ASIDE
	lret	0

