
p	$proc	*
"$dmsa"* $name

LOG*	$func
fulcrum	$equ	LOG(1, 1)-1
	$do	fulcrum<1,	$return	0
?	$do	48,	;
	$do	1*/?>fulcrum,	$return	?
	$return	48
	$end

*	$tree

GRANULES_EXTENT	$equ	1*/LOG((p(1, 2)//64)//((255-5-namez+name)/2))

rfw	+	'A', name-$-1, namez-$-1
granules_extent	+	GRANULES_EXTENT:s
granules_max + p(1, 2)//64d
quanta	0L
extent
	$list	0
	$do	p(1, 2)//64//GRANULES_EXTENT,	0L
	$list
name	"p(1, 1)"
namez
	$root
	$end

