.	oper8	op	[*]table[[subscript]],[b],[column]

p	$proc
oper8*	$name
f	$func
__imm?*	$name	. literal subscript value
	$do	$t(f(1, 1))=127,   $return 0
	$do	$t(f(1, 1))=$equf, $return 0
	$return	1
__subscript* $name
	$return	f(1, 1)
	$end
	
f	$func
__unflag* $name
unflagged $set	f(1, 1)
	$return	unflagged
	$end

	$if	p()>2
__ASIDE	$equf	p(3)
	$else
__ASIDE	$equ	d$save
	$endif

__OP	$equ	p(1, 1)
__INDEX	$equ	__subscript\p(2, 1)
__COLUMN $set	p(2, 3)
	$do	__imm?\p(2, 1),;
__COLUMN $set	__COLUMN+__INDEX
__OFFSET $set	__COLUMN/3
__BIAS	$set	__COLUMN///3

__X	$set	y
	$do	(__OP=sy)++(__OP=ay),;
__X	$set	x

p	$proc
__SX*	$name
	$do	__X=x,	sx	p()
	$do	__X=y,	sy	p()
	$end

p	$proc
__LX*	$name
	$do	__X=x,	lx	p()
	$do	__X=y,	ly	p()
	$end

p	$proc
__AX*	$name
	$do	__X=x,	ax	p()
	$do	__X=y,	ay	p()
	$end

	$if	__imm?\p(2, 1)	. subscript immediate value
	$if	p(2, *1)
	$do	__OP^=ly,	__SX	__ASIDE+2
	__LX	__unflag(p(2, 1))
	$if	__OFFSET<4096
	p(1, 1)	__OFFSET, __X, __BIAS+t1
	$else
	__AX	__OFFSET,,xi
	p(1, 1)	0, __X, __BIAS+t1
	$endif
	$do	__OP^=ly,	__LX	__ASIDE+2
	$else
	p(1, 1)	p(2, 1)+__OFFSET,,__BIAS+t1
	$endif
	$else

__OP1	$equf	(p(1, 1)	0, __X, t1)
__OP2	$equf	(p(1, 1)	0, __X, t2)
__OP3	$equf	(p(1, 1)	0, __X, t3)
__OP4	$equf	(p(1, 1)	1, __X, t1)
__OP5	$equf	(p(1, 1)	1, __X, t2)

	$do	__OP^=ly,	__SX	__ASIDE+2
	ds	__ASIDE
	la	__INDEX
	dsr	24
	d	3,,xi
	$if	p(2, *1)
	__LX	__unflag(p(2, 1))
	$do	__OFFSET^=0,	;
	__AX	__OFFSET,,xi
	$else
	__LX	p(2, 1)+__OFFSET,,i
	$endif
	__AX	a

	$if	  (__OP=sb)++(__OP=orB)++(__OP=andB);
		++(__OP=xorB)++(__OP=ab)++(__OP=anb)
	la	b
	lb	__ASIDE+1
	ex	__OP1+__BIAS, a
	la	__ASIDE
	$elseif	  (__OP=sa)++(__OP=or)++(__OP=and);
		++(__OP=xor)++(__OP=aa)++(__OP=ana)
	la	__ASIDE
	ex	__OP1+__BIAS, b
	lb	__ASIDE+1
	$else
	ex	__OP1+__BIAS,b
	$if	__OP=la
	lb	__ASIDE+1
	$elseif	__OP=lb
	la	__ASIDE
	$else
	dl	__ASIDE
	$endif
	$endif
	$do	__OP^=ly,	__LX	__ASIDE+2
	$endif
	$end

