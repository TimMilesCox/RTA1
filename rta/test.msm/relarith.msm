ABSOLUTE	$equ	-4096
MINUS8		$equ	-8
$(5:*1)
relocatable	$res	1
$(6:06000)

	+	relocatable*/-16	. shift right algebraic 16 after relocation
					. linker range check signed 

	+	relocatable*/-0		. shift no positions, linker range check signed

	+	relocatable*/(-16)	. shift right logical 16 positons after relocation
					. linker range check unsigned

	+	ABSOLUTE*/MINUS8	. shift right algebraic at assembly time

	+	ABSOLUTE*/-8		. shift right algebraic at assembly time	

	+	relocatable/*8		. shift right logical 8 positions after relocation
					. linker range check unsigned

	+	relocatable+EXTERNAL*/-12	. shift right algebraic 12 positions
					. after relocation, linker range check signed

