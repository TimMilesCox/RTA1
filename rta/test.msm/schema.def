p	$proc
area*	$name
*	$tree
area
log	$res	1
slot_location $res 1	. pointer into page_location
page_location $res 2	. long virtual address of extent/page
schema	$res	2	. long virtual address of schema
dbk	$res	2
	$root
	$end


p	$proc	*
subschema* $name

f	$func
pointer* $name	*
	$do	$t(f(1, 1))^=0,	$return	f(1, 1)
	$return	0
	$end

*	$tree
run_actual	$res	1 . index in table
?	$do	AREAS,actual(?)		+	area_(?)
?	$do	RECORDS,record_actual(?) +	record_(?)
. ?	$do	SETS,set_actual(?)		area	. kept in line by find
?	$do	p(1),"area_(p(1, ?))"	area
?	$do	p(2),"record_(p(2, ?))"	area	. kept in line by find
	$root
	$end

p	$proc
dpage*	$name
*	$tree
data	$res	1
slots	$res	1
	$root
	$end

