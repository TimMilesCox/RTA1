	$path		../
	$include	def/rta.def
	$path

ASIDE	$equ	6
STREAM	$equ	d$save
POINTER	$equ	d$save1
ALL	$equ	d$save2
COLUMNS	$equ	d$save3

WORDS	$equ	8


up	lk	0, y
	tp	k
	j	up2_24by1
	tnz	k
	lret	1		. store 1 byte and advance

	src	k
	sc	ALL
	sk	WORDS

	tz	WORDS
	j	up2_48

	lk	1, y
	mta	2, y
	j	up3

	ds	ASIDE
	lsc	k
	sb	COLUMNS
up2_more
	lcal	along
	ds	ASIDE

	tnz	ALL
	lret	0		. margin

	tnz	STREAM
	lret	0		. margin	

	mta	2, y
	lret	0		. margin
	j	up2_more

up3	ay, xi	3
	j	up

	

up2_48	lk, xi	-1
	mta	2, y
	j	up4
	ds	ASIDE
	la	b
	lk	1, y
	mta	3, y
	j	up44

	lsc	k
	lb, i	24, b
	sb	COLUMNS

up4_more
	lcal	along
	ds	ASIDE

	tnz	ALL
	lret	0		. margin

	tnz	STREAM
	lret	0		. margin

	j	up4_more

up44	la	ASIDE
up4	ay, xi	4
	j	up

up2_24by1
	mta	1, y
	j	up2
	ds	ASIDE
	lsc	k
	sb	COLUMNS
	lcal	along
	ds	ASIDE
	lret	0		. margin

up2	ay, xi	2
	j	up
	

along	dl	ASIDE
	ly	COLUMNS
along1	tz	STREAM
	j	along2
	dsl	0, y
	lret	0
along2	dec	STREAM
	inc	POINTER
	rsr	$byte
	rar	$byte
	drl	$byte
	ay,xi	-$byte
	tp	y
	lret	0
	tz	y
	j	along1
	lret	0

