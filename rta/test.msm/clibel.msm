	$path		../
	$include	def/rta.def
	$path

ASIDE	$equ	6
STREAM	$equ	d$save
POINTER	$equ	d$save1
ALL	$equ	d$save2
COLUMNS	$equ	d$save3

DELIMITER $equ	8
CACHE	$equ	9
WORDS	$equ	10
LIST	$equ	11


up	z	DELIMITER
	ly	LIST

up1	lk	0, y
	tp	k
	j	up2_24by1
	tnz	k
	lret	1		. store 1 byte and advance

	src	k
	sc	ALL
	sk	WORDS

	tz	WORDS
	j	up2_48

	lk	1, y
	mta	2, y
	j	up3

	ds	ASIDE
	lsc	k
	sb	COLUMNS
	sy	DELIMITER
up2_more
	lcal	along
	ds	ASIDE

	tnz	ALL
	lret	0		. margin

	tz	CACHE
	tp	CACHE		. nonzero? positively?
	lret	0		. reach here if zero or less

	ly	DELIMITER
	mta	2, y
	lret	0		. margin
	j	up2_more

up3	ay, xi	3
	j	up1


up2_48	lk, xi	-1
	mta	2, y
	j	up4
	ds	ASIDE
	la	b
	lk	1, y
	mta	3, y
	j	up4reload

	lsc	k
	lb, i	24, b
	sb	COLUMNS
	sy	DELIMITER

up4_more
	lcal	along
	ds	ASIDE

	tnz	ALL
	lret	0		. margin

	tz	CACHE
	tp	CACHE		. nonzero? positively?
	lret	0		. margin

	ly	DELIMITER
	lk, xi	-1
	mta	2, y
	lret	0		. margin, delimiter hit
	la	b		. once at least already
	lk	1, y
	mta	3, y
	j	$+2
	j	up4_more	. calls along = reloads a
	la	ASIDE
	lret	0

up4reload
	la	ASIDE
up4	ay, xi	4
	j	up1

up2_24by1
	mta	1, y
	j	up2
	ds	ASIDE
	lsc	k
	sb	COLUMNS
	sy	DELIMITER
	lcal	along
	ds	ASIDE
	lret	0		. margin

up2	ay, xi	2
	j	up1
	
initial	ana	b		. reduce outstanding bytes by POINTER
	ds	STREAM		. POINTER is relative zero here
	ly, xi	48		. startup load CACHE
	sy	CACHE		. after RDATA RDATAC are initialised
	j	along1		. with any subscripts, POINTER etc

along	dl	ASIDE
	ly	COLUMNS
along1	tz	STREAM
	j	along2
	dsl	0, y		. advance width of delimiter

alongz	inc	POINTER		. one column consumed
	push,xi	-$byte		. available bits reduced
	popA	CACHE		. instead of replenished
	ay, xi	-$byte		. count down delimiter width
	tz	x
	tp	x		. hit zero or dived past it
	lret	0
	j	alongz

along2	dec	STREAM		. columns available to load
	inc	POINTER		. one column consumed
	rsr	$byte		. load a column
	rar	$byte
	drl	$byte		. to tail of cache
	ay,xi	-$byte		. count down delimiter width
	tz	y
	tp	y
	lret	0		. hit zero or dived past it
	j	along1

aquif	j	aquif?		. final count r + 1 in all cases
aquif!	lcal	up
	lret	0		. return because a delimiter is walked
	tz	CACHE
	tp	CACHE
	lret	0		. return because no more bytes in stream
	wsr	$byte
	lcal	next
aquif?	jdr	aquif!
	lret	0		. return because no more bytes wanted


next	inc	POINTER		. one column consumed
	tz	STREAM
	j	read1
	push,xi	-$byte		. no more bytes to load
	popA	CACHE		. pay out what's cached
	sar	$byte
	dsl	$byte
	lret	0
read1	dec	STREAM
	sar	$byte
	rsr	$byte		. load a byte
	rar	$byte
	drl	$byte		. to tail of cache
	lret	0

fima	lcal	up
	lret	0		. with DELIMITER written
	tz	CACHE		. this column is not a delimiter
	tp	CACHE
	lret	0		. with DELIMITER clear
	lcal	next
	j	fima

