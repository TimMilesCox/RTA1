	$path		../
	$list		0
	$include	def/rta.def
	$include	language/stack.def
	$list		2
	$path

XQT_FRAME	$equ	64

$(0)
str2stream*	$vector	store_counted
bcmp*		$vector	byte_string_compare

	$list		0
	$do	64-$,	fret	0
	$list		2
	$include	byte_lib

	$do	$<256,$(0:256)
	$list		0
r2atable
?	$do	XQT_FRAME,	la	+(?-1)/3, x, t1+(?-1)///3
dfatable
?	$do	XQT_FRAME,	ana	+(?-1)/3, x, t1+(?-1)///3
	$list
stream_head
?	$do	$word/$byte,	rsr	?*$byte-$byte
stream_offset
?	$do	$word/$byte,	+	?*$byte-$byte
	$do	$zenith>4096,	$flag	constants overflow
