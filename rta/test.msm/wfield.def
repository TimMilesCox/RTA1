p	$proc	. input is in a:b
wfield*	$name
"$offset"	$equ	p(1, 4)
"$positions"	$equ	p(1, 5)
"$range"	$equ	$offset+$positions

	$if	$o('S')
	$trace	$offset
	$trace	$positions
	$trace	$range
	$endif

	$do	$positions>48,	;
	$flag	procedure is for values of size up to 48 bits in a:b

	$if	$range>48
	$do	$o('S'),	$note	> 2 words
	  drr	$range-48
	  sb	p(1)+1
	  lb	p(1)+2
	  drl	$range-48
	  rbr	$range-48
	  sb	p(1)+2
	  lb	p(1)
	  dsl	$offset
	  rar	$offset
	  sa	p(1)
	$elseif	$range<48
	$if	$range>24
	$do	$o('S'),	$note	> 1 word
	$elseif	$range<24
	$do	$o('S'),	$note	< 1 word
	  $if	($SENSE=12)**($positions=12)**($offset///12=0)
	  sb	p(1, 1), p(1, 2), h1+$offset/12
	  $elseif ($SENSE=8)**($positions=8)**($offset///8=0)
	  sb	p(1, 1), p(1, 2), t1+$offset/8
	  $else
	  la	p(1)
	  $do	$offset^=0,	ral	$offset
	  sal	$positions
	  drr	$positions
	  $do	$offset^-0,	rar	$offset
	  sa	p(1)
	  $endif
	$else			. $range=24
	$do	$o('S'),	$note	1 word
	  $if	offset
	  $if	($SENSE=12)**($offset=12)
	  sb	p(1, 1), p(1, 2), h2
	  $elseif ($SENSE=8)**($offset=16)
	  sb	p(1, 1), p(1, 2), t3
	  $else
	  la	p(1)
	  drl	$offset
	  rbr	$offset
	  sa	p(1)
	  $endif
	  $else
	  sb	p(1)
	  $endif
	$endif
	$else			. $range=48
	$do	$o('S'),	$note	2 words
	  $if	$offset
	  sb	p(1)+1
	  $if	($SENSE=12)**($offset=12)
	  sa	p(1, 1), p(1, 2), h2
	  $elseif ($SENSE=8)**($offset=16)
	  sa	p(1, 1), p(1, 2), t3
	  $else
	  lb	p(1)
	  dsl	$offset
	  rar	$offset
	  sa	p(1)
	  $endif
	  $else
	  ds	p(1)
	  $endif
	$endif
	$end

p	$proc
wfieldq*	$name			. input	is	in	a:b:6:7
"$offset"	$equ	p(1, 4)
"$positions"	$equ	p(1, 5)
"$range"	$equ	$offset+$positions

	$if	$o('S')
	$trace	$offset
	$trace	$positions
	$trace	$range
	$endif

	$do	$positions<49,	;
	$flag	procedure is for values larger than 48 bits in a:b:mantissa2:mantissa3

	$if	$range>96
	$do	$o('S'),	$note  > 4 words
	$elseif	$range<96
	$if	$range>72
	$do	$o('S'),	$note	> 3 words
	$elseif	$range<72
	$do	$o('S'),	$note	< 3 words
	$else			. $range=72
	$do	$o('S'),	$note	3 words
	  $if $offset
	  $if	($SENSE=12)**($offset=12)
	  sb	p(1, 1), p(1, 2), h2
	  $elseif ($SENSE=8)**($offset=16)
	  sb	p(1, 1), p(1, 2), t3
	  $else
	  la	p(1)
	  drl	$offset
	  rbr	$offset
	  sb	p(1)
	  $endif
	  $else
	  sb	p(1)
	  $endif
	  dl	6
	  ds	p(1)+1
	$endif
	$else			. $range=96
	$do	$o('S'),	$note	4 words
	  $if	$offset
	  sb	p(1)+1
	  $if	($SENSE=12)**($offset=12)
	  sa	p(1, 1), p(1, 2), h2
	  $elseif ($SENSE=8)**($offset=16)
	  sa	p(1, 1), p(1, 2), t3
	  $else
	  lb	p(1)
	  dsl	$offset
	  rar	$offset
	  sa	p(1)
	  $endif
	  dl	6
	  ds	p(1)+2
	  $else
	  qs	p(1)
	  $endif
	$endif
	$end 
