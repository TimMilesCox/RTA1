AQUIFORM_NET16 $equ	0
COUNTED_STREAM $equ	0
	$byte		12

.	$data_code	'0':0830,0831,0832,0833,0834,0835,0836,0837,0838,0839

	$path		../
	$include	def/rta.def
	$include	language/stack.def
	$include	lib/aquiform.def
	$path
	$list		2
$(0:64)
	$include	iedit48

	$do	$<256,$(0:256)

	$do	'9'>255,	$flag	data code beyond table column range

table
	$list	0
hundreds	$do	10,;
tens		$do	10,;
units		$do	10,	;
	+	hundreds+'0'-1,tens+'0'-1,units+'0'-1
	$list

