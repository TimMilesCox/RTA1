	$path		../
	$include	def/rta.def
	$include	language/i_xpress.def
	$include	language/fpxpress.def
	$path

$(3:03000)
one	$res	4
two	$res	4
first	$res	2
second	$res	2

$(0:64)
        $xqt_fp	(one+two)-(two*one)
	$xqt_fp	+(one+two)
	$xqt_fp	-(one+two)
	$xqt_fp	-(one+two)*2.0
	$xqt_fp	-one+two
	$xqt_fp	0.0-(one+two)
	$xqt_fp	0.0-one+two

	$xqt_i	(first+second)*(second+first)
	$xqt_i	+(first+second)
	$xqt_i	-(first+second)
	$xqt_i	-(first+second)/1000
	$xqt_i	-first+second
	$xqt_i	0:d-(first+second)
	$xqt_i	0L-first+second

	$xqt_fp	33.6*44.7
	$xqt_fp	+(33.6*44.7)

	$do	$<256,$(0:256)

