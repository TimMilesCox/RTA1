p	$proc

"$sapx"*	$name
"$sbpx"*	$name
"$skpx"*	$name
"$zpx"*	$name
"$tzpx"*	$name
"$tppx"*	$name
"$lapx"*	$name
"$lkpx"*	$name
"$lbpx"*	$name
"$orapx"*	$name
"$orbpx"*	$name
"$andapx"*	$name
"$andbpx"*	$name
"$xorapx"*	$name
"$xorbpx"*	$name
"$aapx"*	$name
"$abpx"*	$name
"$anapx"*	$name
"$anbpx"*	$name
"$mpx"*	$name
"$mfpx"*	$name
"$dpx"*	$name

	$if	p(1)>1
	lx	p(1, 1)		. array
	ly	p(1, 2)		. byte subscript
	$else
	lx	p(1, 1)		. byte pointer
	ly	p(1, 1)+1
	$endif

	$if	p(2, 1)<32768
	lr, xi	p(2, 1)
	$else
	lr	(p(2, 1))
	$endif

	$if	p(2, 1)<4096-256
	call	(p(0, 0)_v)
	$else
	call	(p(0, 0)_v_xl)
	$endif

	$end

