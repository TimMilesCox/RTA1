	$path		../
	$include	def/rta.def
	$include	def/vector.def
	$include	def.sys/base.def
	$include	t77.4/dq.def
	$include	t77.4/i_f.def
	$include	t77.4/socket.def
	$include	t77.4/ip.def
	$include	t77.4/ipv4.def
	$include	t77.4/tcp.def
	$path


$(71::,sp)
dgram	datagram

$(67::,y)
transit	segment

$(67::,b)
listen	$socket

$(0)
ip_alternate_rxbank?
	lx, xi	0
	la	dgram:flags_fragment
	and, xi	IP_DNF
	jza	nope
	la	dgram:ttl_protocol
	and, xi	255
	aa, xi	-IPPROTO_TCP
	jnza	nope
	ly	TP_HEADER
	la	transit:sourcep
	lb, xi	A$RXBUFFB*/9
	dsr	9
	aa, xi	tsockb(1)
	la	0, a
	jza	nope
	sabr	A$RXBUFFB
	rbr	12
	lx	listen:tcp:rxbank, b
nope	lret	0

