_lret:	mov	ebx, dword ptr [ebp+S_P]
	add	eax, dword ptr [ebx*4+__register]
	and	eax, 00FFFFFFh	; add return address to +- displacement
	add	ebx, 1
	mov	dword ptr [ebp+S_P], ebx
	jmp	_j
	ret

_fret:	mov	ebx, dword ptr [ebp+S_P]
	mov	edx, eax	; +- displacement
	add	edx, dword ptr [ebx*4+__register+4]
	mov	eax, dword ptr [ebx*4+__register]
	jmp	_go2_bank
	ret
