_leloup:
	push	ebp
	push	esi
	push	edi
	
	push	eax
	push	ebx
	push	ecx
	push	edx

	mov	edx, dword ptr [_apc]
	mov	ebp, dword ptr [_register_set]

loup:	mov	eax, dword ptr [edx]
	bswap	eax
	add	edx, 4
	call	_execute
	%if	METRIC
	inc	dword ptr [_metric]
	%endif

	test	dword ptr [_indication], INDICATIONS
	jz	loup

	mov	dword ptr [_register_set], ebp
	mov	dword ptr [_apc], edx

	pop	edx
	pop	ecx
	pop	ebx
	pop	eax

	pop	edi
	pop	esi
	pop	ebp
	ret

