if [ -z "$RTA_BINARY" ]
then
echo	export $RTA_BINARY=directory-for-new-binaries \
	in your shell profile
echo	and add \$RTA_BINARY to \$PATH
exit	0
fi

if      [ ! -d "$RTA_BINARY" ]
then
mkdir   "$RTA_BINARY"
fi

if	[ $1 == "powerpc" ]
then
	IFLAG=-UINTEL
	echo	constructing for network byte order
else
	IFLAG=-DINTEL
	echo	constructing for Intel byte order
fi


pushd   ../netifx
gcc -m32 -c -funsigned-char $IFLAG -o ../emulator.rel/netbank.o netbank.c
popd

gcc -m32 -c -funsigned-char -o ../emulator.rel/idisplay.o idisplay.c

if	[ -z $RTA_MBANKS ]
then
export	RTA_MBANKS=2
fi

echo	emulated RTA executable space $RTA_MBANKS banks image tiptoe$RTA_MBANKS

if	[ $1 == "powerpc" ]
then
	ARCHFLAG=-UX86
	echo	constructing for powerpc
elif	[ $1 == "llvm" ]
then
	ARCHFLAG=-DX86_LLVM
	echo	constructing LLVM LE
else
	ARCHFLAG=-DX86
	echo	constructing x86 specific
fi

pushd	../engine.rta
./genrel $ARCHFLAG
popd

gcc -m32 -DMBANKS=$RTA_MBANKS -o $RTA_BINARY/tiptoe$RTA_MBANKS	\
				../engine.rel/rta.o		\
				../engine.rel/ii.o		\
				../engine.rel/memory.o		\
				../emulator.rel/netbank.o	\
				../engine.rel/rw.o		\
				../engine.rel/alu.o		\
				../engine.rel/fpu.o		\
				../engine.rel/sr.o		\
				../emulator.rel/idisplay.o	\
				tiptoe.c

echo	binaries in $RTA_BINARY
ls -l $RTA_BINARY
