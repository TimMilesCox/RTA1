
pushd ../netifx
gcc -m32 -c -funsigned-char -o ../emulator.rel/argue.o argue.c
popd

if	[ -z "$RTA_BINARY" ]
then
export	RTA_BINARY=../binary.rta/osx.x86
echo	RTA_BINARY=$RTA_BINARY
fi

if	[ ! -d "$RTA_BINARY" ]
then
mkdir	"$RTA_BINARY"
ls -l	$RTA_BINARY
fi


if [[ "$1" == "powerpc" || "$1" == "sparc" ]]
then
BE=-UINTEL
echo	platform $1
else
BE=-DINTEL
echo	platform little-endian
fi

if [ "$2" == "linux" ]
then
OS=-DLINUX
echo	image for Linux
else
OS=-DOSX
echo	image for OSX
fi

gcc -m32 -funsigned-char $BE $OS -o fp ../emulator.rel/argue.o fp.c
cp fp	$RTA_BINARY
echo	$RTA_BINARY
ls -l	$RTA_BINARY

