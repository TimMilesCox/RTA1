pushd	$HOME/dynamic.rta > /dev/null
if	[ ! -e "dynamic.def" ]
then
cp	$RTA_BINARY/../../target.rta/fponline/dynamic.def .
fi
if	[ ! -e "onlinefp.def" ]
then
touch	onlinefp.def
fi
echo	started mpdu
rm	pdu.txo
rm	pdu
rm	pduimage
masmx	-lnke $RTA_BINARY/../../target.rta/fponline/pdu pdu > list.txt
if	[ ! -e "pdu.txo" ]
then
	echo	error in just-in-time assembly
	echo	possibly exponent underflow / overflow
	echo	see $HOME/dynamic.rta/list.txt
	exit
fi
symbol	< pdu.txo > pduwords
lstring	-b	pdu.txo pdu
source	./pduwords
slab	pdu pduimage $FPONLINE_WORDS	
popd	> /dev/null

