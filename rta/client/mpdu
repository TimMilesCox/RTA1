pushd	$HOME/dynamic.rta > /dev/null
if	[ ! -e "dynamic.def" ]
then
	cp	$RTA_BINARY/../../target.rta/fponline/dynamic.def .
fi

if	[ ! -e "my_names.def" ]
then
	touch	my_names.def
fi
#	echo	started mpdu

if	[ ! -e "/dynamic/rta/fponline/$USER" ]
then
	mkdir	/dynamic/rta/fponline/$USER
	chmod	0777 /dynamic/rta/fponline/$USER
fi

cp	target.def /dynamic/rta/fponline/$USER
cp	target2.def /dynamic/rta/fponline/$USER
#	cp	dynamic.def /dynamic/rta/fponline/$USER
#	cp	my_names.def /dynamic/rta/fponline/$USER
cp	runagate.msm /dynamic/rta/fponline/$USER

cd	/dynamic/rta/fponline/$USER

rm -f	pdu.txo
rm -f	pdu
rm -f	pduimage
masmx	-lnke	$RTA_BINARY/../../target.rta/fponline/pdu	\
		pdu						\
		> list.txt

if	[ ! -e /dynamic/rta/fponline/$USER/pdu.txo ]
then
	echo	error in just-in-time assembly
	echo	see /dynamic/rta/fponline/$USER/list.txt
	exit
fi
symbol	< pdu.txo > pduwords
lstring	-b	pdu.txo pdu
source	./pduwords
slab	pdu pduimage $FPONLINE_WORDS
popd	> /dev/null

