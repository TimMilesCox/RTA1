.	for asymmetrical stack use and generally
.	jumping out of routines with stuff on
.	the stack

.	if this walkback list should be anywhere
.	different from the top of the automatic
.	data page B1, set B1_SP to the required
.	position before or after including this file.

.	that's why B1_SP is $SET and not $EQU


	$do	$t(B1_SP)=0,;
B1_SP		$set		8191

	$do	$t(B1_GUARDED)=0,;
B1_GUARDED	$set		0

b1_sp_start*	$proc
		lx, xi		B1_SP
		sx		0, x
		$end

b1_push_sp*	$proc
		push, i		0, sp	. not push SP !
		dec		B1_SP
		pop		*B1_SP
		$end

b1_pop_sp*	$proc
		push		*B1_SP
		inc		B1_SP
		pop		sp
		$end

.	at entry point when called from
.	code with a different ADP in B1
.	static Automatic Data Page at a
.	known location in the vector
.	bank B2

.	if a parameter list address is
.	expected in A it must be copied
.	away first

.	if a parameter value of two or four
.	words is in A:B or A:B:6:7, that must
.	be stored at 6 or 8 or d$save
.	or else pushed

b1_base*	$proc
		inA		ADP
		lb		b1_base(1, 1)
		outB		ADP

		$if		(B1_SP>4096)**(B1_SP<8192)
		  lb, xi	B1_SP-1
		  ds		B1_SP
		$else
		  dec		B1_SP
		  sa		*B1_SP
		$endif
		$end

.	before returning to a caller
.	which has a different ADP

b1_rebase*	$proc
		lb		*B1_SP
		inc		B1_SP
		outB		ADP

.       any return value in A:B or A:B:6:7
.       must be reloaded after this point
                
		$end


.	entry point of a recursive subprogram

.	it is always assumed that the next
.	page down is available and not the
.	static ADP of another code block
.
.	therefore a recursive subprogram is
.	called from another recursive
.	subprogram, or from the code block
.	with the lowest-address fixed ADP

.	thus:

.	start of------> _________________________
.	program	space	|ultimate available	|
.			|dynamic B1 ADP		|
.			|_______________________|
.			|			|


.			|_______________________|
.			|first available	|
.			|dynamic B1 ADP		|
.			|_______________________|
.			|fixed ADP of lowest	|
.			|address ROUTINE_Z	|
.			|_______________________|
.			|			|


.			|_______________________|
.			|fixed ADP of highest	|
.			|address ROUTINE_A	|
.			|_______________________|
.			|			|
.			|task control block	|
.			|_______________________|
.			|			|
.			|program		|


.		only ROUTINE_Z can call a recursive
.		subprogram

.		but all the recursive subprograms
.		can call back all the fixed code
.		blocks ROUTINE_A...ROUTINE_Z



.       if a parameter value of two or four
.       words is in A:B or A:B:6:7, that must
.       be stored at 6 or 8 or d$save
.       or else pushed


b1_dynamic*	$proc
		inB		ADP
		dec		B
		outB		ADP

		$if		B1_GUARDED
		anb		BASE_VECTOR
		jc		$+2
		ii		$runaway
		$endif

		$if		(B1_SP>4095)**(B1_SP<8192)
		  lb, xi	B1_SP-1
		  sb		B1_SP
		$endif
		$end

.	recursive subprograms must restore
.	the caller's B1 ADP like this

.	a recursive subprogram can jump
.	horizontally to another one instead
.	of returning, but not to a code
.	block with static ADP in B1

b1_dynamic_R*	$proc
		inB		ADP
		inc		B
		outB		ADP

.	any return value in A:B or A:B:6:7
.	must be reloaded after this point

		$end


.	here some routine enter and clear macros
.	for languages like C with arguments on the
.	internal stack, and with a very mobile
.	internal stack pointer. X is kept pointing
.	at the entry stack top, and must be pushed
.	again before it's used for anything else.

.	the stack is cleared by storing X on it

.	X does not need to be pushed before a
.	nested call to the same style of routine

p		$proc
i_routine*	$name
		push	x
		lx	sp
		$end

p		$proc
x_routine*	$name
		sx	sp
		pop	x
		$end
