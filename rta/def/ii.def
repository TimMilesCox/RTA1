YIELD$		$equ	65	.	bank 1	vector	1
SPAWN$		$equ	66	.	bank 1	vector	2
BANK$		$equ	67	.	bank 1	vector	3
ARRAY$		$equ	68	.	bank 1	vector	4
BANK$FREE	$equ	69	.	bank 1	vector	5
EXIT$		$equ	70	.	bank 1	vector	6

HANDLE$		$equ	80	.	bank 1	vector	16
FREE_HANDLE$	$equ	81	.	bank 1	vector	17
READ_HANDLE$	$equ	82	.	bank 1	vector	18
READ_XVECTOR$	$equ	83	.	bank 1	vector	19
WRITE_XVECTOR$	$equ	84	.	bank 1	vector	20
READ_SOCKET$	$equ	85	.	bank 1	vector	21
UHANDLE$	$equ	86	.	bank 1	vector	22
KERNEL$B1	$equ	87	.	bank 1	vector	23
B1$		$equ	88	.	bank 1	vector	24
KERNEL$B1_1	$equ	89	.	bank 1	vector	25
DAYCLOCK$W	$equ	90	.	bank 1	vector	26
TWAIT$		$equ	91	.	bank 1	vector	27


REALTIME$_CLOCK	$equ	144	.	interrupt register 16
				.	instruction ration
				.	= effective time slice
				.	if the running task
				.	is time-sliced

				.	register increments
				.	from negative value
				.	once per instruction.
				.	on zero YIELD interrupt
				.	is automatic

				.	no action unless
				.	register 144 contains
				.	a minus value

				.	loaded at context switch
				.	the application can't
				.	write register 144

PRIORITY$	$equ	145	.	interrupt register 17
				.	quick look up of the
				.	running task priority
				.	loaded at context switch

DAYCLOCK$U	$equ	146	.	tick since uptime upper
DAYCLOCK$	$equ	147	.	tick since uptime

TIMER$		$equ	94	.	bank 1	vector	30
TIMER$IMASK	$equ	4

XBASE_U$	$equ	95	.	bank 1 vector 31
				.	not a software interrupt
				.	application code attempt to
				.	base a device array
				.	SABR instruction guarded

				.	same hardware interrupt
				.	called as a software
				.	interrupt: recursive
				.	subprogram attempted to
				.	base an unavailable ADP
				.	in B1

RUNAWAY$	$equ	XBASE_U$ .	macro code issued this
				.	II instruction
				.	depends on assembly setting
				.	B1_GUARDED

STACK_LIMIT$	$equ	XBASE_U$ .	same vector again
				.	initiated by software if the
				.	internal stack pointer is
				.	about to go too low because
				.	an application is placing too
				.	many dynamic variables in the
				.	internal stack

?	$do	12,XBASE$(?+32-1)	$equ	?+96-1

				.	bank 1 vectors 32..63
				.	request to base a device array

MAX_INT_MASK	$equ	7
