GRANULE$ $equ	64
DIRECTORY$BLOCK $equ GRANULE$*16
FS24$_BANK_HIGH_INDEX $equ 65535


VOLUME$	$equ	'V'
FILE$	$equ	'F'
MOUNT$	$equ	'M'
DIRECTORY$ $equ 'D'
BOOT$FILE $equ	'B'
EXTENT$	$equ	'X'
LINK$	$equ	'L'
RELAY$	$equ	'@'
LIST$END $equ	'Z'

DIRECTORY_NAME_OFFSET$ $equ EXTENT1_WORDS$+2

p	$proc
"$filetree"* $name
*	$tree
e	$extent1
list_write_point
	+	16
list_space
	+	DIRECTORY$BLOCK-16
name
	$root
	$end


DATAFILE_NAME_OFFSET$ $equ EXTENT2_WORDS$+2

p	$proc
"$filetag"* $name
*	$tree
e	$extent2
quanta	+	0:d
name
	$root
	$end

EXTENT1_WORDS$ $equ	4

p	$proc			. this extent is for
"$extent1"* $name		. directories and volumes
*	$tree
rfw	+	'X', 0, EXTENT1_WORDS$
granules +	p(1, 1)
granule +	p(1, 2):d
	$root
	$end

EXTENT2_WORDS$ $equ	7

p	$proc			. this extent is for files
"$extent2"* $name
*	$tree
rfw	+	'X', 0, EXTENT2_WORDS$
granules +	p(1, 1)
granule	+	p(1, 2):d	. the granule of the data
next	+	p(1, 3:1):d	. granule next descriptor
next_offset +	p(1, 3:2)	. word offset next descriptor
	$root	
	$end

