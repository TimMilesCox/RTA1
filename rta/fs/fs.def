.	these maintain the caller's open file state
.	They are access blocks


FS$NONE		$equ	0	. never opened

.		< zero = one of the following inverted on close

FS$CORE		$equ	1	. ROM / RAM executable space FS
FS$DEVICE$ARRAY	$equ	2	. FS in device array

p		$proc
filep*		$name
*		$tree		. user state serial read part
fs_type		$res	1	. core FS / external device / NFS client
device				. external device address or...
bank		$res	1	. core start bank
extent		$res	2	. long pointer to current extent descriptor
absolute_pointer $res	2	. word offset in the total file system
		$root
		$end

p		$proc
fileq*		$name
*		$tree		. user state read / rewind / seek
serialp		filep		. the 6 words used for serial read
rewind_extentp	$res	2	. 1st extent descriptor pointer
quantum_pointer	$res	2	. accumulated offset in the file
		$root
		$end

f	$func
LOG24*	$name
fulcrum	$equ	f(1, 1)-1
	$do	fulcrum<1,	$return	0
?	$do	24,	$do	1*/?>fulcrum,	$return	?
	$return	24
	$end

