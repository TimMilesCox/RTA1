if	[ $1 == "PCAP" ]
then
	BINARY=pcapserv
	METHOD=-DPCAP
	PCAPLIB=/usr/lib/libpcap.dylib
else
	BINARY=pktserv
	METHOD=-UPCAP
fi

gcc -m32 -funsigned-char	-DINTERFACES=6 		\
				-DINTEL			\
				$METHOD			\
				-o $RTA_BINARY/$BINARY	\
				../emulator.rel/argue.o	\
				../emulator.rel/portal.o \
				$PCAPLIB		\
				pcapserv.c

