"$operator" $equ	193

plus	$equ, $operator	1
minus	$equ, $operator	2
times	$equ, $operator	3
over	$equ, $operator	4
cover	$equ, $operator	5
modulo	$equ, $operator	6
"$d"	$equ, $operator 7
"$u"	#equ, $operator 87

	$text	/+/ plus /
	$text	/-/ minus /
	$text	/*/ times /
	$text	-/- over /
	$text	-//- cover -
	$text	-///- modulo -
	$text	/ (/ $0(/
	$text	/(/ $d /
	$text	/)/ $u /

f	$func
"$op"*	$name
	$do	$t(f(1, 1))=$operator,	$return	f(1, 1)
	$return	0
	$end

	+	$op(+)
	+	$op(plus)

p	$proc
assign*	$name

p	$proc

p	$proc
add*	$name
	
	$end

start	$set	p(0, 2)
tokens	$set	p()-start
?	$do	tokens,	$do	$op(?+start, 1)=$d,	assign	p(?+1)

?	$do	tokens,	$do	$op(?+start, 1)=plus,	add	p(start) p(?+1)
	$end

$(0:64/$0)
	assign	1+1
