TCB	$equ	4096

TDESCRIPTOR $equ TCB+1
ULIMIT	$equ	TCB+3
BANK_CHAIN $equ	TCB+4
B1_P	$equ	TCB+5
THREADS	$equ	TCB+6
NEXT_THREAD $equ TCB+7

UPACKET	$equ	TCB+60
ABT	$equ	TCB+64
RSAVE	$equ	TCB+128


	$if	0
FREE_HANDLE $equ TCB+256	. points to a free chain start
HANDLES	$equ	TCB+257		. this contains the address + 2 of the
				. highest 48-bit handle encoding written

?	$do	4,handle(?)	$equ	FREE_HANDLE+?*2

HANDLES_MAX $equ 7*1024		. TCB + 3072 = the highest write address + 2
				. allowed for new 48-bit  handle encodings
	$endif
