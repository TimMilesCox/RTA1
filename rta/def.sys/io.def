.	system control I/O port numbers and mask values


OVERFLOWER$	$equ	96	. incrementer start count output port

DAYCLOCK_UPDATE$ $equ	97	. advertise new dayclock value
				. interrupt multicast

ALERT_REQUEST$	$equ	98	. advise target core[s] to yield thread
				. interrupt unicast or multicast

ATTENTION_REQUEST$ $equ	99	. request target core[s]
				. to service resources
				. interrupt unicast or multicast

sys$switch	$equ	126	. board settings input port
sys$leds	$equ	127	. board LEDS output port

device$flags	$equ	128
ram$threshold	$equ	124


DEVICE_PRESENT  $equ    0800000
FS24    	$equ    DEVICE_PRESENT++0400000
BOOT_FILE_PRESENT $equ  0200000

I_F_16BIT_FLAGS	$equ	DEVICE_PRESENT++0080000


