write_udigit_code(3)
	lcal	write_udigit_code(1)
write_udigit_code(2)
	lcal	write_udigit_code(1)
write_udigit_code(1)

	$if	$byte<8

	sal	8-$byte
	wsr	$byte

	$else

	push	a
	sar	16
	la	digit_code-('0'**255), a

	$if	AQUIFORM_NET16**($byte>16)
	wsr	16
	wsr	$byte-16
	$else
	wsr	$byte
	$endif

	pop	a
	sal	8
	$endif

	lret	0

