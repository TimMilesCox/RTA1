"$$EOS_FLAG"	$set	0	. deliver zero iteravely after delivering counted field
				. nonzero = deliver BYTES + 1 bytes, then -1 iteravely


. this equate goes in the assembly wrapper
. COUNTED_STREAM $equ 1	. a field or message size limit
			. in register BYTES is heeded

			. BYTES can be progressively
			. decremented in several scan
			. primitive routine calls


READ_STREAM_START* $proc
	sa	q	. once per input buffer
	z	RDATAC
	$end


READ_START* $proc	. once per input specification
	$if	AQUIFORM_NET16
	on	b$stream16r++b$streamZR
	$else
	on	b$streamZR
	off	b$stream16r
	$endif
	$end		. it is up to the calling application
			. to change b$stream16R back if it needs

READ_BYTE* $proc *
	$if	COUNTED_STREAM
	la	BYTES

	$if	$$EOS_FLAG	. for counted data including zero value bytes
	jna	already	. deliver BYTES + 1 bytes and then deliver -1 iteravely
	$else			. for data terminated by zero or by count
	jza	already	. deliver BYTES bytes and then deliver zero iteravely
	$endif

	dec	BYTES
	$endif		. otherwise data is zero-terminated and not counted

	rsr	$byte

already	sa	LAST_BYTE_READ
	$end

WRITE_START* $proc
	$if	AQUIFORM_NET16
	on	b$stream16w
	$else
	off	b$stream16w
	$endif
	$end

WRITE_OBYTE* $proc
	.	if the output is already full-sized in current character code
	$if	AQUIFORM_NET16**($byte>16)
	wsr	16
	wsr	$byte-16
	$else
	wsr	$byte
	$endif
	$do	COUNTED_STREAM,	inc	BYTES
	$end

WRITE_BYTE* $proc
	sal	$word-$byte
	$if	AQUIFORM_NET16**($byte>16)
	wsr	16
	wsr	$byte-16
	$else
	wsr	$byte
	$endif
	$do	COUNTED_STREAM,	inc	BYTES
	$end

WRITE_UPPER_BYTE* $proc
WRITE_UBYTE*	$name
	$if	$byte=8
	wsr	$byte
	$else
	lcal	write_udigit_data
	$endif
	$do	COUNTED_STREAM,	inc	BYTES
	$end

WRITE3_BYTES* $proc
	$if	$byte=8
	$if	AQUIFORM_NET16
	wsr	$byte*2
	wsr	$byte
	$else
	wsr	24
	$endif
	$else
	lcal	write_udigit_code(3)
	$endif

	$if	COUNTED_STREAM
	push,xi	3
	popA	BYTES
	$endif
	$end

WRITE_BYTES*	$proc
bits	$set	WRITE_BYTES(1, 1)*$byte

	$if	$byte=8
	$if	AQUIFORM_NET16**(bits>16)
	wsr	16
	wsr	bits-16
	$else
	wsr	bits
	$endif
	$else
	lcal	write_udigit_code(WRITE_BYTES(1, 1))
	$endif

	$if	COUNTED_STREAM
	push, xi bits/$byte
	popA	BYTES
	$endif
	$end

	

HORIZONTAL_TAB $equ 9	. the code does not know this library
			. is 8-bit ASCII
			. only this wrapper knows that

