scale_out192*
	lx	(lcal	uprate192),,xi
	ly	pplu192(1),,xi
	lr	8,,xi
	lcal	scale_up
	lx	(lcal	trialm192),,xi
	ly	pmin192(21),,xi
	lr	-8,,xi
	lcal	scale_down

	on	fp$r
	fa	$residue
	off	fp$r

	lk	(07FFFFF)
	mta	(0400000)
	j	scale192_out
	qpush	8
	on	fp$r
	fm	(1*+1)
	off	fp$r
	qpush	a
	ql	4, sp
	fm	(1*+1)
	fa	$residue
	qs	4, sp
	qpop	a
	qpop	8
scale192_out
	lret	0

scale_out*
	lx	(fm	upward, y),,xi
	lr	4,,xi
	ly	0,,xi
	lcal	scale_up
	lx	(fm	downward, y),,xi
	ly	pminus(21)-pminus(1),,xi
	lr	-4,,xi
	lcal	scale_down
	qs	8
	lret	0

scale_up
	lk	(0400000)
	z	SCALE
	n	SCALE
	push	r
	lr	21-1,,xi

rescale	mta	(0)
	j	midpoint
	ex	0, x
	ay	0, sp
	off	carry$
	slc	SCALE
	jdr	rescale

midpoint
	inc	SCALE
	pop	r
	lret	0

scale_down
	push	r
	lr	21-1,,xi
	push	0,,xi

scale_down?
	qpush	a
	ex	0, x
	off	carry$
	mta	(0400000)
	j	scale_under
	on	carry$
	qs	0, sp
scale_under
	slc	4, sp
	qpop	a
	ay	1, sp
	jdr	scale_down?
	popA	SCALE
	pop	r
	lret	0


trialm192
	qpush	8
	qpush	8
	qpush	a
	lc	flm	0,sp,i
	la	0, sp		. retrieve the resulting exponent
	mta	(0400000)
	j	trialx192	. keep the old values
	ql	8		. take the new minor product
	qs	8, sp
trialx192
	qpop	a
	qpop	8
	qpop	8
	lret	0

uprate192			. no test involved
	qpush	8
	qpush	a
	lc	flm	0,sp,i
	qpop	a
	qpop	8
	lret	0

