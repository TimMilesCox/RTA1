NETMASK_ABSOLUTE	$equ	MAX_INT_MASK

CHECK_TS_CELL* $proc	. check developer remembered
			. to give an argument, and 
			. that it seems to be a
			. writable storage address

			. the address range is only
			. checked if neither indexing
			. nor indirection applies,
			. otherwise the effective
			. address is not predictable
			. at assembly time

			. only an assembly time check
			. for any very obvious mistake

			. there is no range check at
			. runtime

	$do		p(1, *1),	$return
	$do		p(1, 2)^=0,	$return
	$if		p(1, 1)<4096
	$if		p(1, 1)<256
	$flag		test and set cell is a register
	$else
	$note		test and set cell is in ;
			instruction + constant space
	$endif
	$endif
	$end

LOCK*	$proc		. prevent all interrupts
			. while in possession of
			. the resource,

			. by switching the active
			. interrupt mask with the
			. maximum mask on the
			. stack top

			. instruction SIM exchanges
			. the active network mask
			. PSR bits 22:16
			. with a storage operand,
			. here a word at the
			. internal stack top

			. then lock the resource
			. with TS instruction

	push, xi	NETMASK_ABSOLUTE
	sim		0, sp
	ts		LOCK(1)
	j		$-1
	CHECK_TS_CELL	LOCK(1)
	$end

FREE*	$proc		. finally free the resource
			. and allow interrupts at
			. the former level

			. THE STACK STATE MUST BE
			. EXACTLY AS SET BY LOCK

			. restore the stack state

	z		FREE(1)
	sim		0, sp
	inc		sp
	CHECK_TS_CELL	FREE(1)
	$end

OPEN*	$proc		. momentarily free the resource
			. and allow interrupts at the
			. former level

			. THE STACK STATE MUST BE
			. EXACTLY AS SET BY LOCK

	z		OPEN(1)
	sim		0, sp
	CHECK_TS_CELL	OPEN(1)
	$end

SHUT*	$proc		. take the resource back after
			. momentarily reliquishing

			. THE STACK STATE MUST BE
			. EXACTLY AS SET BY LOCK

	sim		0, sp
	ts		SHUT(1)
	j		$-1
	CHECK_TS_CELL	SHUT(1)
	$end

