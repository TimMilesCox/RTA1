INTERFACES $set	8
RPAGEW	$equ	1024
RPAGES	$equ	128

RX_BASE	$equ	32
TX_BASE	$equ	32

ETHERNET_CSMACD  $equ	6
SOFTWARELOOPBACK $equ	24
FIREWALL_RELAY	 $equ	100

softwareLoopback $equ	SOFTWARELOOPBACK
firewall_relay	$equ	FIREWALL_RELAY

SOFTWARE_I_F $equ 1
WITH_BRAKES  $equ 2

i_f*	$proc
*	$tree

id	+	?
flags	+	?=1
address_list +	i_f(?, 1)
type	+	i_f(?, 3)
mtu	+	i_f(?, 2)
state	+	1

bitrate +	1000000000000:d
physa	+	$1(i_f(?, 10:1),i_f(?, 10:2),i_f(?, 10:3),;
		   i_f(?, 10:4),i_f(?, 10:5),i_f(?, 10:6):d)

lastchange	+	0:d

inoctets +	0:d
outoctets +	0:d
inpackets +	0:d
outpackets +	0:d

inmcast	+	0:d
outmcast +	0:d

indrops	+	0:d
outdrops +	0:d

inerrs	+	0:d
outerrs	+	0:d

inoproto +	0:d

oqlen	+	0


description +	$1("i_f(?, 3)")

lock_cell_q1 +	0
lock_cell_q2 +	0

oq	dq

	$if	HVBANK
hvoq	hvdq
	$endif

initial		+	i_f(?, 4)
rxtx_interface	+	i_f(?, 5)

ift1	$branch

base_rx	+	0
rx_cursor +	RX_BASE*/18:s
base_tx	+	0
tx_cursor +	TX_BASE*/18++RPAGES*RPAGEW**262143:s
	$root

sif	$branch

latent_data +	0
	$root

	$root

	$end

