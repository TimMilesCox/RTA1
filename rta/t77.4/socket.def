PD_INET	$equ	0800

. UDP	$equ	17	. protocol tag + handle type
. TCP	$equ	6	. protocol tag + handle type

TCP_TCB	$equ	63	. connection handle
			. not a protocol tag
			. but a handle type tag

SOCKET_NO_PROTOCOL	$equ	-1
SOCKET_ENGAGED		$equ	-2

f	$func
"$net_ipv4"* $name

net	$set	0
	$sterm	'.'

?	$do	f(1, 1:),;
net	$set	net*/8++f(1, 1:?)

	$sterm	':'

	$return	net
	$end


"$netp"	$form	32, 16

p		$proc
"$socket"*	$name
*		$tree
socket_address	$netp
remote_address	$netp
tbase
socket_inq	dq
tsq		+	0
mbase		+	0
		$root
		$end


p		$proc
tcp_connection*	$name
*		$tree

next		+	0
automatic_fin
state		+	TCP_LISTEN
mss		+	576
tsq		+	0

?		$do	2,;
timer(?)	+	0

socket_address	$netp
remote_address	$netp

remote_ack_window +	0:d
sequence_ackx	+	0:d
ack_window	+	0:d

receiveq	dq
deferq		dq
q4window	dq
q4ack		dq

		$root
		$end

